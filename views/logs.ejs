<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Insights &gt; <span class="text-zinc-200">System Activity Logs</span></div>
        <a href="/" class="text-xs text-zinc-400 hover:text-white">&larr; Back to Dashboard</a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto space-y-6">
        <div>
            <h1 class="text-white text-xl font-bold tracking-tight">System Audit &amp; Activity Trail</h1>
            <p class="text-zinc-500 text-xs mt-1">Verify chronological administrative action logs, security events, and invoice generations.</p>
        </div>

        <div class="bg-[#111111] border border-[#262626] rounded-xl overflow-hidden shadow-lg">
            <table class="w-full text-left border-collapse text-xs font-mono">
                <thead>
                    <tr class="border-b border-[#1F1F1F] bg-[#161616] text-[10px] font-bold text-zinc-500 uppercase tracking-wider font-sans">
                        <th class="p-4">Timestamp</th>
                        <th class="p-4">Action Event</th>
                        <th class="p-4">Detailed Audit Log Remarks</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#1F1F1F] text-zinc-300">
                    <% if (logs && logs.length > 0) { %>
                        <% logs.forEach(log => { %>
                            <tr class="hover:bg-[#161616]/20">
                                <td class="p-4 text-zinc-400 font-sans"><%= new Date(log.created_at).toLocaleString() %></td>
                                <td class="p-4 font-bold font-sans">
                                    <span class="px-2 py-0.5 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded text-[9px] uppercase tracking-wider">
                                        <%= log.action %>
                                    </span>
                                </td>
                                <td class="p-4 text-zinc-300 font-sans"><%= log.details %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="p-12 text-center text-zinc-500 font-sans">
                                No activity logs found in system audit database.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
