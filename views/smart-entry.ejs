<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<%
    const safeCities = (typeof cities !== 'undefined' && Array.isArray(cities)) ? cities : [];
    const safeAreas = (typeof areas !== 'undefined' && Array.isArray(areas)) ? areas : [];
    const safeProperties = (typeof properties !== 'undefined' && Array.isArray(properties)) ? properties : [];
    const safeUnits = (typeof units !== 'undefined' && Array.isArray(units)) ? units : [];
    const safeTenants = (typeof tenants !== 'undefined' && Array.isArray(tenants)) ? tenants : [];

    const todayObject = new Date();
    const todayValue = todayObject.toISOString().slice(0, 10);
    const agreementEndObject = new Date(todayObject);
    agreementEndObject.setFullYear(agreementEndObject.getFullYear() + 1);
    agreementEndObject.setDate(agreementEndObject.getDate() - 1);
    const agreementEndValue = agreementEndObject.toISOString().slice(0, 10);
%>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header bar -->
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Dashboard &gt; <span class="text-zinc-200">Unified Smart Entry Wizard</span></div>
        <a href="/" class="text-xs text-zinc-400 hover:text-white transition-colors">&larr; Back to Dashboard</a>
    </header>

    <!-- Scrollable content area -->
    <div id="wizard-scroll" class="p-8 flex-1 overflow-y-auto max-w-4xl mx-auto w-full space-y-6">
        <div>
            <h1 class="text-white text-xl font-bold tracking-tight flex items-center gap-2">
                <span class="p-1 px-2.5 bg-blue-500/10 text-blue-400 rounded-md text-sm">⚡</span>
                Unified Smart Entry Wizard
            </h1>
            <p class="text-zinc-400 text-xs mt-1">Beginner-friendly step-by-step setup. Feed city, area, property, unit, tenant, lease agreement and payments simultaneously.</p>
        </div>

        <% if (typeof error_msg !== 'undefined' && error_msg) { %>
            <div id="error-banner" class="p-4 bg-red-950/45 border border-red-500/20 text-red-400 text-xs rounded-xl flex items-center justify-between">
                <span><%= error_msg %></span>
                <button onclick="this.parentElement.remove()" class="text-red-500 hover:text-red-300 font-bold">&times;</button>
            </div>
        <% } %>

        <!-- Wizard Progress Bar -->
        <div class="bg-[#111111] border border-[#262626] p-4 rounded-xl flex items-center justify-between shadow-md select-none">
            <div class="flex items-center gap-2 text-xs">
                <span id="step-indicator-1" class="w-6 h-6 rounded-full flex items-center justify-center font-bold bg-blue-600 text-white transition-colors">1</span>
                <span class="text-zinc-200 font-medium">Property Node</span>
            </div>
            <div class="flex-1 h-px bg-zinc-800 mx-4"></div>
            <div class="flex items-center gap-2 text-xs">
                <span id="step-indicator-2" class="w-6 h-6 rounded-full flex items-center justify-center font-bold bg-[#1F1F1F] text-zinc-500 transition-colors">2</span>
                <span class="text-zinc-500 font-medium">Rental Unit</span>
            </div>
            <div class="flex-1 h-px bg-zinc-800 mx-4"></div>
            <div class="flex items-center gap-2 text-xs">
                <span id="step-indicator-3" class="w-6 h-6 rounded-full flex items-center justify-center font-bold bg-[#1F1F1F] text-zinc-500 transition-colors">3</span>
                <span class="text-zinc-500 font-medium">Tenant Profile</span>
            </div>
            <div class="flex-1 h-px bg-zinc-800 mx-4"></div>
            <div class="flex items-center gap-2 text-xs">
                <span id="step-indicator-4" class="w-6 h-6 rounded-full flex items-center justify-center font-bold bg-[#1F1F1F] text-zinc-500 transition-colors">4</span>
                <span class="text-zinc-500 font-medium">Lease &amp; Payment</span>
            </div>
        </div>

        <!-- Master Form -->
        <form action="/smart-entry" method="POST" id="smart-entry-form" class="space-y-6">
            
            <!-- STEP 1: City, Area, Property -->
            <div id="step-section-1" class="bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-6">
                <div>
                    <h2 class="text-white font-semibold text-base">Step 1: Location &amp; Property Details</h2>
                    <p class="text-zinc-500 text-xs mt-0.5">Select a pre-existing municipal sector &amp; estate or click corresponding options to register them instantly.</p>
                </div>

                <!-- City Subsegment -->
                <div class="border-t border-[#1F1F1F] pt-4 space-y-4">
                    <div class="flex justify-between items-center">
                        <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest flex items-center gap-1.5">
                            <span class="inline-block w-1 h-3 bg-blue-500 rounded"></span> City Information
                        </h3>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">City Setup Mode</label>
                            <div class="grid grid-cols-2 gap-2">
                                <label class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2">
                                    <input type="radio" name="city_mode" value="select" checked onchange="toggleCityMode('select')" class="accent-blue-500">
                                    <span>Select Existing</span>
                                </label>
                                <label class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2">
                                    <input type="radio" name="city_mode" value="new" onchange="toggleCityMode('new')" class="accent-blue-500">
                                    <span>+ Add New City</span>
                                </label>
                            </div>
                        </div>

                        <!-- Select City Dropdown -->
                        <div id="city-select-wrapper">
                            <label for="city_id" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Choose City</label>
                            <select id="city_id" name="city_id" onchange="onCityChanged(this.value)"
                                    class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                                <option value="">-- Choose City --</option>
                                <% safeCities.forEach(c => { %>
                                    <option value="<%= c.id %>"><%= c.name %> (<%= c.province %>)</option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- New City Creation Inputs -->
                        <div id="city-new-wrapper" class="hidden grid grid-cols-2 gap-2">
                            <div>
                                <label for="new_city_name" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">City Name</label>
                                <input type="text" id="new_city_name" name="new_city_name" placeholder="e.g. Islamabad"
                                       class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-700 focus:outline-none focus:border-blue-500/80 transition-all">
                            </div>
                            <div>
                                <label for="new_city_province" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Province</label>
                                <select id="new_city_province" name="new_city_province"
                                        class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                                    <option value="Khyber Pakhtunkhwa">Khyber Pakhtunkhwa (KPK)</option>
                                    <option value="Punjab">Punjab</option>
                                    <option value="Federal Capital">Federal Capital</option>
                                    <option value="Sindh">Sindh</option>
                                    <option value="Balochistan">Balochistan</option>
                                    <option value="Gilgit Baltistan">Gilgit Baltistan</option>
                                    <option value="Azad Kashmir">Azad Kashmir</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Area Subsegment -->
                <div class="border-t border-[#1F1F1F] pt-4 space-y-4">
                    <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest flex items-center gap-1.5">
                        <span class="inline-block w-1 h-3 bg-blue-500 rounded"></span> Area Information
                    </h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Area Setup Mode</label>
                            <div class="grid grid-cols-2 gap-2">
                                <label id="area-select-label" class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2 pointer-events-none opacity-50">
                                    <input type="radio" id="area_mode_select" name="area_mode" value="select" checked onchange="toggleAreaMode('select')" class="accent-blue-500">
                                    <span>Select Existing</span>
                                </label>
                                <label id="area-new-label" class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2">
                                    <input type="radio" id="area_mode_new" name="area_mode" value="new" onchange="toggleAreaMode('new')" class="accent-blue-500">
                                    <span>+ Add New Area</span>
                                </label>
                            </div>
                        </div>

                        <!-- Select Area Dropdown -->
                        <div id="area-select-wrapper">
                            <label for="area_id" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Choose Area</label>
                            <select id="area_id" name="area_id" onchange="onAreaChanged(this.value)" disabled
                                    class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all opacity-60">
                                <option value="">-- Choose Area --</option>
                            </select>
                        </div>

                        <!-- New Area Input -->
                        <div id="area-new-wrapper" class="hidden">
                            <label for="new_area_name" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">New Area Name</label>
                            <input type="text" id="new_area_name" name="new_area_name" placeholder="e.g. Sector G-11 or Saddar Bazaar"
                                   class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-700 focus:outline-none focus:border-blue-500/80 transition-all">
                        </div>
                    </div>
                </div>

                <!-- Property Subsegment -->
                <div class="border-t border-[#1F1F1F] pt-4 space-y-4">
                    <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest flex items-center gap-1.5">
                        <span class="inline-block w-1 h-3 bg-blue-500 rounded"></span> Property Node
                    </h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Property Setup Mode</label>
                            <div class="grid grid-cols-2 gap-2">
                                <label id="prop-select-label" class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2 pointer-events-none opacity-50">
                                    <input type="radio" id="property_mode_select" name="property_mode" value="select" checked onchange="togglePropMode('select')" class="accent-blue-500">
                                    <span>Select Existing</span>
                                </label>
                                <label id="prop-new-label" class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2">
                                    <input type="radio" id="property_mode_new" name="property_mode" value="new" onchange="togglePropMode('new')" class="accent-blue-500">
                                    <span>+ Add New Property</span>
                                </label>
                            </div>
                        </div>

                        <!-- Select Property Dropdown -->
                        <div id="property-select-wrapper">
                            <label for="property_id" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Choose Property</label>
                            <select id="property_id" name="property_id" onchange="onPropertyChanged(this.value)" disabled
                                    class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all opacity-60">
                                <option value="">-- Choose Property --</option>
                            </select>
                        </div>
                    </div>

                    <!-- New Property Details Forms -->
                    <div id="property-new-wrapper" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 p-4 rounded-xl border border-dashed border-zinc-800 bg-[#141414]">
                        <div class="col-span-1 md:col-span-2">
                            <h4 class="text-zinc-200 text-xs font-semibold">New Property Node Parameters</h4>
                        </div>
                        <div>
                            <label for="new_property_name" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Property Name</label>
                            <input type="text" id="new_property_name" name="new_property_name" placeholder="e.g. Centaurus Executive Plaza"
                                   class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        </div>
                        <div>
                            <label for="new_property_type" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Property Type</label>
                            <select id="new_property_type" name="new_property_type"
                                    class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                                <option value="Plaza">Plaza</option>
                                <option value="House">House</option>
                                <option value="Shop">Shop Line / Mall</option>
                                <option value="Office">Office Plaza</option>
                                <option value="Flat">Apartment Flat Block</option>
                                <option value="Other">Other Category</option>
                            </select>
                        </div>
                        <div class="col-span-1 md:col-span-2">
                            <label for="new_property_address" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Full Physical Location / Address</label>
                            <input type="text" id="new_property_address" name="new_property_address" placeholder="e.g. Plot 3-B, Main Jinnah Avenue Road..."
                                   class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        </div>
                    </div>
                </div>

                <!-- Footer Navigation Buttons for Step 1 -->
                <div class="flex justify-end pt-4 border-t border-[#1F1F1F]">
                    <button type="button" onclick="goToStep(2)" id="step-1-next" disabled class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 disabled:bg-[#1A1A1A] disabled:text-zinc-600 disabled:border-zinc-800 text-white font-semibold text-xs rounded-md shadow-lg transition-all active:scale-[0.98]">
                        Next: Configure Unit &rarr;
                    </button>
                </div>
            </div>

            <!-- STEP 2: Floors & Units -->
            <div id="step-section-2" class="bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-6 hidden">
                <div>
                    <h2 class="text-white font-semibold text-base">Step 2: Setup Unit details</h2>
                    <p class="text-zinc-500 text-xs mt-0.5">Define which apartment, shop, desk location, or office suite is being leased.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Unit Selection Mode</label>
                        <div class="grid grid-cols-2 gap-2">
                            <label id="unit-select-label" class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2">
                                <input type="radio" id="unit_mode_select" name="unit_mode" value="select" checked onchange="toggleUnitMode('select')" class="accent-blue-500">
                                <span>Select Existing Unit</span>
                            </label>
                            <label id="unit-new-label" class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2">
                                <input type="radio" id="unit_mode_new" name="unit_mode" value="new" onchange="toggleUnitMode('new')" class="accent-blue-500">
                                <span>+ Create New Unit</span>
                            </label>
                        </div>
                    </div>

                    <!-- Select Unit Dropdown -->
                    <div id="unit-select-wrapper">
                        <label for="unit_id" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2 font-mono">Select Unit Code</label>
                        <select id="unit_id" name="unit_id" onchange="onUnitChanged(this.value)"
                                class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                            <option value="">-- Choose Unit --</option>
                        </select>
                    </div>
                </div>

                <!-- New Unit Configuration Dashboard -->
                <div id="unit-new-wrapper" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 p-5 rounded-xl border border-dashed border-zinc-800 bg-[#141414]">
                    <div class="col-span-1 md:col-span-2">
                        <h4 class="text-zinc-200 text-xs font-semibold">New Unit Specifications</h4>
                    </div>
                    <div>
                        <label for="new_unit_name" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Unit Name / Number</label>
                        <input type="text" id="new_unit_name" name="new_unit_name" placeholder="e.g. Shop G-05 or Flat 102"
                               class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    </div>
                    <div>
                        <label for="new_unit_floor_name" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Floor Level</label>
                        <select id="new_unit_floor_name" name="new_unit_floor_name"
                                class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                            <option value="Ground Floor">Ground Floor</option>
                            <option value="First Floor">First Floor</option>
                            <option value="Second Floor">Second Floor</option>
                            <option value="Third Floor">Third Floor</option>
                            <option value="Basement">Basement Level</option>
                            <option value="Roof Top">Roof Top</option>
                        </select>
                    </div>
                    <div>
                        <label for="new_unit_type" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Unit Category Type</label>
                        <select id="new_unit_type" name="new_unit_type"
                                class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                            <option value="Shop">Shop</option>
                            <option value="Apartment">Apartment</option>
                            <option value="Office">Office Suite</option>
                            <option value="Room">Standard Room</option>
                            <option value="Flat">Standard Flat</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div>
                        <label for="new_unit_rent_amount" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Base Expected Monthly Rent (₨)</label>
                        <input type="number" id="new_unit_rent_amount" name="new_unit_rent_amount" placeholder="e.g. 35000" oninput="syncRentInput(this.value)"
                               class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    </div>
                    <div>
                        <label for="new_unit_status" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Initial Unit Status</label>
                        <select id="new_unit_status" name="new_unit_status"
                                class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                            <option value="Rented" selected>Rented (Auto Assign)</option>
                            <option value="Vacant">Vacant</option>
                            <option value="Maintenance">Maintenance Break</option>
                        </select>
                    </div>
                </div>

                <!-- Footer Navigation Buttons for Step 2 -->
                <div class="flex justify-between pt-4 border-t border-[#1F1F1F]">
                    <button type="button" onclick="goToStep(1)" class="px-4 py-2 bg-[#1A1A1A] border border-[#262626] text-zinc-400 hover:text-white hover:bg-[#222222] text-xs font-semibold rounded-md transition-all">
                        &larr; Back
                    </button>
                    <button type="button" onclick="goToStep(3)" id="step-2-next" disabled class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 disabled:bg-[#1A1A1A] disabled:text-zinc-600 disabled:border-zinc-800 text-white font-semibold text-xs rounded-md transition-all active:scale-[0.98]">
                        Next: Client Information &rarr;
                    </button>
                </div>
            </div>

            <!-- STEP 3: Tenant Information -->
            <div id="step-section-3" class="bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-6 hidden">
                <div>
                    <h2 class="text-white font-semibold text-base">Step 3: Tenant / Client Information</h2>
                    <p class="text-zinc-500 text-xs mt-0.5">Connect an existing tenant profile from the ledger or input personal credentials for a new client.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Tenant Profile Type</label>
                        <div class="grid grid-cols-2 gap-2">
                            <label class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2">
                                <input type="radio" name="tenant_mode" value="select" checked onchange="toggleTenantMode('select')" class="accent-blue-500">
                                <span>Select Registered</span>
                            </label>
                            <label class="border border-[#262626] bg-[#161616] px-4 py-2 rounded-lg cursor-pointer text-xs text-zinc-300 hover:border-zinc-700 flex items-center gap-2">
                                <input type="radio" name="tenant_mode" value="new" onchange="toggleTenantMode('new')" class="accent-blue-500">
                                <span>+ New Registration</span>
                            </label>
                        </div>
                    </div>

                    <!-- Select Tenant Dropdown -->
                    <div id="tenant-select-wrapper">
                        <label for="tenant_id" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Choose Tenant Profile</label>
                        <select id="tenant_id" name="tenant_id" onchange="onTenantChanged(this.value)"
                                class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                            <option value="">-- Choose Tenant --</option>
                            <% safeTenants.forEach(t => { %>
                                <option value="<%= t.id %>"><%= t.name %> (<%= t.phone || 'No phone' %> - CNIC: <%= t.cnic || 'N/A' %>)</option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <!-- Register New Tenant Profile Segment -->
                <div id="tenant-new-wrapper" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 p-5 rounded-xl border border-dashed border-zinc-800 bg-[#141414]">
                    <div class="col-span-1 md:col-span-2">
                        <h4 class="text-zinc-200 text-xs font-semibold">New Profile Personal Information</h4>
                    </div>
                    <div>
                        <label for="new_tenant_name" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Tenant Name *</label>
                        <input type="text" id="new_tenant_name" name="new_tenant_name" placeholder="e.g. junaid ali" oninput="onTenantNewFieldsChanged()"
                               class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    </div>
                    <div>
                        <label for="new_tenant_father_name" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Father's Name</label>
                        <input type="text" id="new_tenant_father_name" name="new_tenant_father_name" placeholder="e.g. Zaman Ali"
                               class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    </div>
                    <div>
                        <label for="new_tenant_cnic" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">CNIC Card Number</label>
                        <input type="text" id="new_tenant_cnic" name="new_tenant_cnic" placeholder="e.g. 17301-1234567-9"
                               class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    </div>
                    <div>
                        <label for="new_tenant_phone" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Phone Number *</label>
                        <input type="text" id="new_tenant_phone" name="new_tenant_phone" placeholder="e.g. 0333-1234567" oninput="onTenantNewFieldsChanged()"
                               class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    </div>
                    <div class="col-span-1 md:col-span-2">
                        <label for="new_tenant_address" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Permanent Residential Address</label>
                        <input type="text" id="new_tenant_address" name="new_tenant_address" placeholder="e.g. Sector H, Phase 4, Hayatabad, Peshawar"
                               class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    </div>
                    <div>
                        <label for="new_tenant_emergency_contact" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Emergency Contact Details</label>
                        <input type="text" id="new_tenant_emergency_contact" name="new_tenant_emergency_contact" placeholder="e.g. Brother: 0300-1122334"
                               class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    </div>
                    <div>
                        <label for="new_tenant_notes" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Brief Notes / Business Category</label>
                        <input type="text" id="new_tenant_notes" name="new_tenant_notes" placeholder="e.g. Cloth merchant or software developer"
                               class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    </div>
                </div>

                <!-- Footer Navigation Buttons for Step 3 -->
                <div class="flex justify-between pt-4 border-t border-[#1F1F1F]">
                    <button type="button" onclick="goToStep(2)" class="px-4 py-2 bg-[#1A1A1A] border border-[#262626] text-zinc-400 hover:text-white hover:bg-[#222222] text-xs font-semibold rounded-md transition-all">
                        &larr; Back
                    </button>
                    <button type="button" onclick="goToStep(4)" id="step-3-next" disabled class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 disabled:bg-[#1A1A1A] disabled:text-zinc-600 disabled:border-zinc-800 text-white font-semibold text-xs rounded-md transition-all active:scale-[0.98]">
                        Next: Lease Agreements &amp; Payments &rarr;
                    </button>
                </div>
            </div>

            <!-- STEP 4: Lease & Financial Information -->
            <div id="step-section-4" class="bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-6 hidden">
                <div>
                    <h2 class="text-white font-semibold text-base">Step 4: Rent Agreement &amp; Payments Setup</h2>
                    <p class="text-zinc-500 text-xs mt-0.5">Determine the lease contracts constraints and finalize outstanding payments collections parameters.</p>
                </div>

                <!-- Section: Agreement -->
                <div class="border-t border-[#1F1F1F] pt-4 space-y-4">
                    <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest flex items-center gap-1.5">
                        <span class="inline-block w-1 h-3 bg-blue-500 rounded font-bold"></span> Rent Agreement Variables
                    </h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="agreement_start_date" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Agreement Start Date</label>
                            <input type="date" id="agreement_start_date" name="agreement_start_date" required value="<%= todayValue %>"
                                   class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all font-mono">
                        </div>
                        <div>
                            <label for="agreement_end_date" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Agreement End Date</label>
                            <input type="date" id="agreement_end_date" name="agreement_end_date" required value="<%= agreementEndValue %>"
                                   class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all font-mono">
                        </div>
                        <div>
                            <label for="agreement_monthly_rent" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Finalized Monthly Rent (₨)</label>
                            <input type="number" id="agreement_monthly_rent" name="agreement_monthly_rent" required placeholder="e.g. 35000"
                                   class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all font-mono">
                        </div>
                        <div>
                            <label for="agreement_advance_amount" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Advance Security Amount (₨)</label>
                            <input type="number" id="agreement_advance_amount" name="agreement_advance_amount" required value="100000" placeholder="e.g. 100000"
                                   class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all font-mono">
                        </div>
                        <div class="col-span-1 md:col-span-2">
                            <label for="agreement_notes" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Agreement Terms / Remarks (Optional)</label>
                            <input type="text" id="agreement_notes" name="agreement_notes" placeholder="e.g. standard residential terms with 10% annual increase limits."
                                   class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-700 focus:outline-none focus:border-blue-500/80 transition-all">
                        </div>
                    </div>
                </div>

                <!-- Section: Payments and Receipts setup -->
                <div class="border-t border-[#1F1F1F] pt-4 space-y-4">
                    <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest flex items-center gap-1.5">
                        <span class="inline-block w-1 h-3 bg-emerald-500 rounded font-bold"></span> Ledger Payment Generation
                    </h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 bg-[#141414] p-4 rounded-xl border border-dashed border-[#262626]">
                        <div>
                            <label class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Record Advance Security Payment?</label>
                            <select name="record_advance_payment" class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                                <option value="yes" selected>Yes, Paid Automatically</option>
                                <option value="no">No (Will show as unpaid/pending)</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-2">Record First Month Rent Payment?</label>
                            <select name="record_first_rent" class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all font-sans">
                                <option value="yes" selected>Yes, Paid Fully (₨ <%= new Date().toLocaleDateString('en-US', {month: 'long', year: 'numeric'}) %>)</option>
                                <option value="no">No, Pending Arrears</option>
                            </select>
                        </div>

                        <div>
                            <label for="payment_date" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Collection/Payment Date</label>
                            <input type="date" id="payment_date" name="payment_date" value="<%= todayValue %>"
                                   class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all font-mono">
                        </div>

                        <div>
                            <label for="payment_method" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Payment Method Category</label>
                            <select id="payment_method" name="payment_method"
                                    class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all font-sans">
                                <option value="Cash" selected>Cash Handover</option>
                                <option value="Bank Transfer">Bank Transfer (HBL/Allied)</option>
                                <option value="EasyPaisa">EasyPaisa e-wallet</option>
                                <option value="JazzCash">JazzCash e-wallet</option>
                                <option value="Cheque">Standard Bank Cheque</option>
                                <option value="Other">Other Method</option>
                            </select>
                        </div>

                        <div class="col-span-1 md:col-span-2">
                            <label for="payment_remarks" class="block text-[11px] font-semibold text-zinc-400 uppercase tracking-wider mb-1.5">Payment Remarks / Reference (Optional)</label>
                            <input type="text" id="payment_remarks" name="payment_remarks" placeholder="e.g. Collected via cash. Receipt voucher no #23"
                                   class="w-full px-3 py-2 bg-[#1A1A1A] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all font-sans">
                        </div>
                    </div>
                </div>

                <!-- Footer Navigation Buttons for Step 4 -->
                <div class="flex justify-between pt-4 border-t border-[#1F1F1F]">
                    <button type="button" onclick="goToStep(3)" class="px-4 py-2 bg-[#1A1A1A] border border-[#262626] text-zinc-400 hover:text-white hover:bg-[#222222] text-xs font-semibold rounded-md transition-all">
                        &larr; Back
                    </button>
                    <button type="submit" class="px-6 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs rounded-md shadow-lg shadow-emerald-950/20 transition-all active:scale-[0.98]">
                        ⚡ Finish &amp; Submit Smart Record
                    </button>
                </div>
            </div>

        </form>
    </div>
</main>

<script>
    const rawAreas = <%- JSON.stringify(safeAreas).replace(/</g, '\\u003c') %>;
    const rawProperties = <%- JSON.stringify(safeProperties).replace(/</g, '\\u003c') %>;
    const rawUnits = <%- JSON.stringify(safeUnits).replace(/</g, '\\u003c') %>;

    let currentStep = 1;
    let isSubmitting = false;

    const byId = (id) => document.getElementById(id);
    const asId = (value) => String(value ?? '');
    const asNumber = (value) => {
        const number = Number(value);
        return Number.isFinite(number) ? number : 0;
    };

    function getRadioValue(name) {
        const selected = document.querySelector(`input[name="${name}"]:checked`);
        return selected ? selected.value : '';
    }

    function setRadioValue(name, value) {
        const radio = document.querySelector(`input[name="${name}"][value="${value}"]`);
        if (radio && !radio.disabled) radio.checked = true;
    }

    function setWrapperState(wrapperId, visible) {
        const wrapper = byId(wrapperId);
        if (!wrapper) return;

        wrapper.classList.toggle('hidden', !visible);
        wrapper.querySelectorAll('input, select, textarea').forEach((field) => {
            field.disabled = !visible;
        });
    }

    function setLabelDisabled(labelId, disabled) {
        const label = byId(labelId);
        if (!label) return;

        label.classList.toggle('opacity-50', disabled);
        label.classList.toggle('pointer-events-none', disabled);

        const input = label.querySelector('input');
        if (input) input.disabled = disabled;
    }

    function setSelectEnabled(select, enabled) {
        if (!select) return;
        select.disabled = !enabled;
        select.classList.toggle('opacity-60', !enabled);
    }

    function resetSelect(selectId, placeholder, enabled = false) {
        const select = byId(selectId);
        if (!select) return;
        select.innerHTML = `<option value="">${placeholder}</option>`;
        setSelectEnabled(select, enabled);
    }

    function formatMoney(value) {
        return asNumber(value).toLocaleString('en-PK');
    }

    function validateStep1() {
        const cityMode = getRadioValue('city_mode');
        const areaMode = getRadioValue('area_mode');
        const propertyMode = getRadioValue('property_mode');

        const cityValid = cityMode === 'new'
            ? Boolean(byId('new_city_name')?.value.trim())
            : Boolean(byId('city_id')?.value);

        const areaValid = areaMode === 'new'
            ? Boolean(byId('new_area_name')?.value.trim())
            : Boolean(byId('area_id')?.value);

        const propertyValid = propertyMode === 'new'
            ? Boolean(byId('new_property_name')?.value.trim())
            : Boolean(byId('property_id')?.value);

        const valid = cityValid && areaValid && propertyValid;
        byId('step-1-next').disabled = !valid;
        return valid;
    }

    function validateStep2() {
        const unitMode = getRadioValue('unit_mode');
        const valid = unitMode === 'new'
            ? Boolean(byId('new_unit_name')?.value.trim())
            : Boolean(byId('unit_id')?.value);

        byId('step-2-next').disabled = !valid;
        return valid;
    }

    function validateStep3() {
        const tenantMode = getRadioValue('tenant_mode');
        const valid = tenantMode === 'new'
            ? Boolean(byId('new_tenant_name')?.value.trim()) && Boolean(byId('new_tenant_phone')?.value.trim())
            : Boolean(byId('tenant_id')?.value);

        byId('step-3-next').disabled = !valid;
        return valid;
    }

    function updateAllValidation() {
        validateStep1();
        validateStep2();
        validateStep3();
    }

    function goToStep(stepNumber) {
        if (stepNumber < 1 || stepNumber > 4) return;

        if (stepNumber > currentStep) {
            if (currentStep === 1 && !validateStep1()) return;
            if (currentStep === 2 && !validateStep2()) return;
            if (currentStep === 3 && !validateStep3()) return;
        }

        byId(`step-section-${currentStep}`)?.classList.add('hidden');
        byId(`step-section-${stepNumber}`)?.classList.remove('hidden');

        for (let index = 1; index <= 4; index++) {
            const indicator = byId(`step-indicator-${index}`);
            if (!indicator) continue;

            const label = indicator.nextElementSibling;

            if (index === stepNumber) {
                indicator.className = 'w-6 h-6 rounded-full flex items-center justify-center font-bold bg-blue-600 text-white transition-colors duration-200';
                if (label) label.className = 'text-zinc-200 font-medium transition-colors duration-200';
            } else if (index < stepNumber) {
                indicator.className = 'w-6 h-6 rounded-full flex items-center justify-center font-bold bg-emerald-600/20 text-emerald-400 border border-emerald-500/20 transition-colors duration-200';
                if (label) label.className = 'text-zinc-400 font-medium transition-colors duration-200';
            } else {
                indicator.className = 'w-6 h-6 rounded-full flex items-center justify-center font-bold bg-[#1F1F1F] text-zinc-500 transition-colors duration-200';
                if (label) label.className = 'text-zinc-500 font-medium transition-colors duration-200';
            }
        }

        currentStep = stepNumber;
        byId('wizard-scroll')?.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function toggleCityMode(mode) {
        const isNew = mode === 'new';
        setWrapperState('city-select-wrapper', !isNew);
        setWrapperState('city-new-wrapper', isNew);

        if (isNew) {
            resetSelect('area_id', '-- Choose Area --');
            resetSelect('property_id', '-- Choose Property --');
            resetSelect('unit_id', '-- Choose Unit --');

            setLabelDisabled('area-select-label', true);
            setLabelDisabled('prop-select-label', true);
            setLabelDisabled('unit-select-label', true);

            setRadioValue('area_mode', 'new');
            toggleAreaMode('new');
        } else {
            const cityId = byId('city_id')?.value || '';
            setLabelDisabled('area-select-label', !cityId);
            onCityChanged(cityId);
        }

        updateAllValidation();
    }

    function toggleAreaMode(mode) {
        const isNew = mode === 'new';
        setWrapperState('area-select-wrapper', !isNew);
        setWrapperState('area-new-wrapper', isNew);

        if (isNew) {
            resetSelect('property_id', '-- Choose Property --');
            resetSelect('unit_id', '-- Choose Unit --');

            setLabelDisabled('prop-select-label', true);
            setLabelDisabled('unit-select-label', true);

            setRadioValue('property_mode', 'new');
            togglePropMode('new');
        } else {
            const areaId = byId('area_id')?.value || '';
            setLabelDisabled('prop-select-label', !areaId);
            if (areaId) onAreaChanged(areaId);
        }

        updateAllValidation();
    }

    function togglePropMode(mode) {
        const isNew = mode === 'new';
        setWrapperState('property-select-wrapper', !isNew);
        setWrapperState('property-new-wrapper', isNew);

        if (isNew) {
            resetSelect('unit_id', '-- Choose Unit --');
            setLabelDisabled('unit-select-label', true);
            setRadioValue('unit_mode', 'new');
            toggleUnitMode('new');
        } else {
            const propertyId = byId('property_id')?.value || '';
            setLabelDisabled('unit-select-label', !propertyId);
            if (propertyId) onPropertyChanged(propertyId);
        }

        updateAllValidation();
    }

    function toggleUnitMode(mode) {
        const isNew = mode === 'new';
        setWrapperState('unit-select-wrapper', !isNew);
        setWrapperState('unit-new-wrapper', isNew);
        validateStep2();
    }

    function toggleTenantMode(mode) {
        const isNew = mode === 'new';
        setWrapperState('tenant-select-wrapper', !isNew);
        setWrapperState('tenant-new-wrapper', isNew);
        validateStep3();
    }

    function onCityChanged(cityId) {
        resetSelect('area_id', '-- Choose Area --');
        resetSelect('property_id', '-- Choose Property --');
        resetSelect('unit_id', '-- Choose Unit --');

        if (!cityId) {
            setLabelDisabled('area-select-label', true);
            setRadioValue('area_mode', 'new');
            toggleAreaMode('new');
            return;
        }

        const matchedAreas = rawAreas.filter((area) => asId(area.city_id) === asId(cityId));

        if (matchedAreas.length === 0) {
            setLabelDisabled('area-select-label', true);
            setRadioValue('area_mode', 'new');
            toggleAreaMode('new');
            return;
        }

        const areaSelect = byId('area_id');
        matchedAreas.forEach((area) => {
            const option = document.createElement('option');
            option.value = asId(area.id);
            option.textContent = area.name || 'Unnamed Area';
            areaSelect.appendChild(option);
        });

        setSelectEnabled(areaSelect, true);
        setLabelDisabled('area-select-label', false);
        setRadioValue('area_mode', 'select');
        setWrapperState('area-select-wrapper', true);
        setWrapperState('area-new-wrapper', false);
        setLabelDisabled('prop-select-label', true);
        setLabelDisabled('unit-select-label', true);
        updateAllValidation();
    }

    function onAreaChanged(areaId) {
        resetSelect('property_id', '-- Choose Property --');
        resetSelect('unit_id', '-- Choose Unit --');

        if (!areaId) {
            setLabelDisabled('prop-select-label', true);
            setRadioValue('property_mode', 'new');
            togglePropMode('new');
            return;
        }

        const cityId = byId('city_id')?.value || '';
        const matchedProperties = rawProperties.filter((property) =>
            asId(property.city_id) === asId(cityId) &&
            asId(property.area_id) === asId(areaId)
        );

        if (matchedProperties.length === 0) {
            setLabelDisabled('prop-select-label', true);
            setRadioValue('property_mode', 'new');
            togglePropMode('new');
            return;
        }

        const propertySelect = byId('property_id');
        matchedProperties.forEach((property) => {
            const option = document.createElement('option');
            option.value = asId(property.id);
            option.textContent = `${property.name || 'Unnamed Property'} (${property.property_type || 'Other'})`;
            propertySelect.appendChild(option);
        });

        setSelectEnabled(propertySelect, true);
        setLabelDisabled('prop-select-label', false);
        setRadioValue('property_mode', 'select');
        setWrapperState('property-select-wrapper', true);
        setWrapperState('property-new-wrapper', false);
        setLabelDisabled('unit-select-label', true);
        updateAllValidation();
    }

    function onPropertyChanged(propertyId) {
        resetSelect('unit_id', '-- Choose Unit --');
        validateStep1();

        if (!propertyId) {
            setLabelDisabled('unit-select-label', true);
            setRadioValue('unit_mode', 'new');
            toggleUnitMode('new');
            return;
        }

        const matchedUnits = rawUnits
            .filter((unit) => asId(unit.property_id) === asId(propertyId))
            .sort((left, right) => {
                const orderDifference = asNumber(left.sort_order) - asNumber(right.sort_order);
                if (orderDifference !== 0) return orderDifference;
                return String(left.name || '').localeCompare(String(right.name || ''), undefined, { numeric: true });
            });

        if (matchedUnits.length === 0) {
            setLabelDisabled('unit-select-label', true);
            setRadioValue('unit_mode', 'new');
            toggleUnitMode('new');
            return;
        }

        const unitSelect = byId('unit_id');
        matchedUnits.forEach((unit) => {
            const option = document.createElement('option');
            option.value = asId(unit.id);
            option.textContent = `${unit.name || 'Unnamed Unit'} [${unit.unit_type || 'Unit'}] — ${unit.status || 'Unknown'} — ₨ ${formatMoney(unit.rent_amount)}/mo`;
            unitSelect.appendChild(option);
        });

        setSelectEnabled(unitSelect, true);
        setLabelDisabled('unit-select-label', false);
        setRadioValue('unit_mode', 'select');
        setWrapperState('unit-select-wrapper', true);
        setWrapperState('unit-new-wrapper', false);
        validateStep2();
    }

    function onUnitChanged(unitId) {
        validateStep2();
        if (!unitId) return;

        const unit = rawUnits.find((item) => asId(item.id) === asId(unitId));
        if (!unit) return;

        byId('agreement_monthly_rent').value = asNumber(unit.rent_amount) || '';
        if (asNumber(unit.advance_amount) > 0) {
            byId('agreement_advance_amount').value = asNumber(unit.advance_amount);
        }
    }

    function syncRentInput(value) {
        byId('agreement_monthly_rent').value = value;
    }

    function onTenantChanged() {
        validateStep3();
    }

    function onTenantNewFieldsChanged() {
        validateStep3();
    }

    document.addEventListener('DOMContentLoaded', () => {
        const listeners = [
            ['new_city_name', 'input', validateStep1],
            ['new_area_name', 'input', validateStep1],
            ['new_property_name', 'input', validateStep1],
            ['new_unit_name', 'input', validateStep2],
            ['new_tenant_name', 'input', validateStep3],
            ['new_tenant_phone', 'input', validateStep3]
        ];

        listeners.forEach(([id, eventName, handler]) => {
            byId(id)?.addEventListener(eventName, handler);
        });

        const form = byId('smart-entry-form');
        form?.addEventListener('submit', (event) => {
            if (isSubmitting) {
                event.preventDefault();
                return;
            }

            if (!validateStep1()) {
                event.preventDefault();
                goToStep(1);
                return;
            }

            if (!validateStep2()) {
                event.preventDefault();
                goToStep(2);
                return;
            }

            if (!validateStep3()) {
                event.preventDefault();
                goToStep(3);
                return;
            }

            if (!form.checkValidity()) {
                event.preventDefault();
                form.reportValidity();
                return;
            }

            isSubmitting = true;
            const submitButton = form.querySelector('button[type="submit"]');
            if (submitButton) {
                submitButton.disabled = true;
                submitButton.textContent = 'Saving Smart Record...';
            }
        });

        setWrapperState('city-select-wrapper', true);
        setWrapperState('city-new-wrapper', false);
        setWrapperState('area-select-wrapper', true);
        setWrapperState('area-new-wrapper', false);
        setWrapperState('property-select-wrapper', true);
        setWrapperState('property-new-wrapper', false);
        setWrapperState('unit-select-wrapper', true);
        setWrapperState('unit-new-wrapper', false);
        setWrapperState('tenant-select-wrapper', true);
        setWrapperState('tenant-new-wrapper', false);

        setLabelDisabled('area-select-label', true);
        setLabelDisabled('prop-select-label', true);
        setLabelDisabled('unit-select-label', true);
        resetSelect('area_id', '-- Choose Area --');
        resetSelect('property_id', '-- Choose Property --');
        resetSelect('unit_id', '-- Choose Unit --');

        updateAllValidation();
    });
</script>

<%- include('partials/footer') %>
