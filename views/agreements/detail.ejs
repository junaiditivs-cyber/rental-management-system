<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">
            Rent Agreements &gt; <span class="text-zinc-200">Contract #<%= agreement.id %> Details</span>
        </div>
        <div class="flex gap-2">
            <a href="/agreements/<%= agreement.id %>/edit" class="px-4 py-1.5 bg-[#1C1C1E] border border-zinc-800 text-zinc-300 text-xs font-semibold rounded hover:text-white transition-colors">
                Edit Contract Parameters
            </a>
            <form action="/agreements/<%= agreement.id %>/delete" method="POST" class="inline" 
                  onsubmit="return confirm('WARNING: Are you sure you want to delete this Rent Agreement record? All historical ties might be lost.');">
                <button type="submit" class="px-4 py-1.5 bg-red-950/20 border border-red-900/30 text-red-400 text-xs font-semibold rounded hover:bg-red-900/40 transition-colors">
                    Delete Agreement
                </button>
            </form>
        </div>
    </header>

    <!-- Content panel -->
    <div class="p-8 flex-1 overflow-y-auto space-y-8">
        
        <!-- Status Alert Banner -->
        <div class="bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-4 shadow-lg">
            <div class="flex justify-between items-start">
                <div>
                    <span class="px-2 py-0.5 bg-[#1C1C1E] border border-[#2E2E30] text-[9px] font-mono rounded text-zinc-400 font-bold uppercase tracking-wider">
                        Rent Lease Agreement File
                    </span>
                    <h1 class="text-white text-2xl font-black tracking-tight mt-1">Agreement Node ID: <%= agreement.id %></h1>
                    <p class="text-zinc-500 text-xs">Lease allocated between tenant <strong class="text-zinc-300"><%= tenant ? tenant.name : 'Unknown' %></strong> and unit <strong class="text-zinc-300"><%= unit ? unit.name : 'Unknown' %></strong></p>
                </div>

                <!-- Custom status label -->
                <div>
                    <% if(agreement.status === 'Active') { %>
                        <span class="px-3 py-1.5 bg-emerald-950/60 border border-emerald-500/20 text-emerald-400 font-bold font-mono text-xs rounded-lg uppercase">Active contract</span>
                    <% } else { %>
                        <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-500 font-bold font-mono text-xs rounded-lg uppercase">Contract Ended</span>
                    <% } %>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-4 border-t border-[#1F1F1F] text-sm">
                <div class="bg-[#161616] p-4 rounded-lg border border-[#262626]">
                    <div class="text-[10px] uppercase font-bold text-zinc-500">Monthly Rent Fee</div>
                    <div class="text-xl font-bold font-mono text-zinc-100 mt-1">₨ <%= agreement.monthly_rent.toLocaleString() %></div>
                </div>
                <div class="bg-[#161616] p-4 rounded-lg border border-[#262626]">
                    <div class="text-[10px] uppercase font-bold text-zinc-500">Security Advance Deposit</div>
                    <div class="text-xl font-bold font-mono text-zinc-100 mt-1">₨ <%= agreement.advance_amount.toLocaleString() %></div>
                </div>
                <div class="bg-blue-950/10 p-4 rounded-lg border border-blue-900/20">
                    <div class="text-[10px] uppercase font-bold text-blue-400">Fixed Due Date Day</div>
                    <div class="text-xl font-bold font-mono text-blue-300 mt-1">Every <%= agreement.due_day %>th</div>
                </div>
            </div>
        </div>

        <!-- Contract Details -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-4 shadow-md">
                <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest border-b border-[#1F1F1F] pb-2">Contract Dates &amp; Notes</h3>
                <div class="grid grid-cols-2 gap-4 text-xs">
                    <div>
                        <div class="text-zinc-500 font-bold">Start Date</div>
                        <div class="text-zinc-200 mt-1 font-mono text-sm"><%= agreement.start_date %></div>
                    </div>
                    <div>
                        <div class="text-zinc-500 font-bold">End Date</div>
                        <div class="text-zinc-200 mt-1 font-mono text-sm"><%= agreement.end_date %></div>
                    </div>
                </div>
                <% if(agreement.notes) { %>
                    <div class="pt-2">
                        <div class="text-zinc-500 font-bold text-[10px] uppercase">Remarks / Contract Commitments</div>
                        <p class="text-zinc-300 text-xs bg-zinc-950 p-3 rounded-md border border-zinc-900 mt-1"><%= agreement.notes %></p>
                    </div>
                <% } %>
            </div>

            <!-- Documents -->
            <div class="bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-4 shadow-md flex flex-col justify-between">
                <div>
                    <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest border-b border-[#1F1F1F] pb-2">Document Attachments</h3>
                    <div class="text-xs text-zinc-400 mt-4 leading-relaxed">
                        <% if(agreement.agreement_doc_url) { %>
                            <div class="p-4 bg-zinc-950 border border-zinc-900 rounded-md flex justify-between items-center">
                                <span>Attached Contract PDF</span>
                                <a href="<%= agreement.agreement_doc_url %>" target="_blank" class="text-blue-400 font-bold hover:underline" referrerpolicy="no-referrer">Download &darr;</a>
                            </div>
                        <% } else { %>
                            <span class="text-zinc-650 italic">No agreement documents uploaded for this contract block.</span>
                        <% } %>
                    </div>
                </div>

                <div class="pt-4 flex gap-2 w-full">
                    <a href="/rent/collect?unit_id=<%= agreement.unit_id %>" class="flex-1 text-center py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded text-xs">
                        Record Payment
                    </a>
                </div>
            </div>
        </div>

    </div>
</main>

<%- include('../partials/footer') %>
