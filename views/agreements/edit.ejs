<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Agreements &gt; <span class="text-zinc-200">Edit Contract Specs</span></div>
        <a href="javascript:history.back()" class="text-xs text-zinc-400 hover:text-white transition-colors">&larr; Cancel</a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto max-w-2xl space-y-6 font-sans">
        <div>
            <h1 class="text-white text-lg font-bold tracking-tight">Edit Rent Agreement Details</h1>
            <p class="text-zinc-500 text-xs mt-1">Configure negotiated rates, advance security expectations, start/end dates, and the fixed monthly installment due date day.</p>
        </div>

        <% if (locals.error_msg) { %>
            <div class="p-4 bg-red-950/30 border border-red-500/20 text-red-500 text-xs rounded-xl flex items-center justify-between shadow-md">
                <div class="flex items-center gap-2">
                    <span>⚠️</span>
                    <span><%= error_msg %></span>
                </div>
                <button onclick="this.parentElement.remove()" class="text-red-500 font-bold">&times;</button>
            </div>
        <% } %>

        <form action="/agreements/<%= agreement.id %>/edit" method="POST" class="bg-[#111111] border border-[#262626] p-6 rounded-xl space-y-4">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Connected Tenant Account</label>
                    <input type="text" readonly value="<%= tenant ? tenant.name : 'Unknown' %>" 
                           class="w-full px-3 py-2 bg-zinc-950 border border-zinc-90 w-full rounded-md text-zinc-400 text-sm focus:outline-none cursor-not-allowed">
                </div>

                <div>
                    <label class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Connected Unit Box</label>
                    <input type="text" readonly value="<%= unit ? unit.name : 'Unknown' %>" 
                           class="w-full px-3 py-2 bg-zinc-950 border border-zinc-90 w-full rounded-md text-zinc-400 text-sm focus:outline-none cursor-not-allowed">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-[#1F1F1F] pt-4">
                <div>
                    <label for="monthly_rent" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Monthly Rent Rate (PKR)</label>
                    <input type="number" id="monthly_rent" name="monthly_rent" required value="<%= agreement.monthly_rent %>"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none font-mono">
                </div>

                <div>
                    <label for="advance_amount" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Security Advance Amount (PKR)</label>
                    <input type="number" id="advance_amount" name="advance_amount" required value="<%= agreement.advance_amount %>"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none font-mono">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label for="start_date" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Start Date</label>
                    <input type="date" id="start_date" name="start_date" required value="<%= agreement.start_date %>"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none font-mono">
                </div>

                <div>
                    <label for="end_date" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">End Date</label>
                    <input type="date" id="end_date" name="end_date" required value="<%= agreement.end_date %>"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none font-mono">
                </div>

                <div>
                    <label for="due_day" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5 text-blue-400 font-bold">Fixed Due Day of Month</label>
                    <input type="number" id="due_day" name="due_day" required min="1" max="28" value="<%= agreement.due_day %>"
                           class="w-full px-3 py-2 bg-[#161616] border border-blue-500/30 rounded-md text-white text-sm focus:outline-none focus:border-blue-500 font-mono" title="Dates above 28 are disabled to prevent month overflow errors">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="status" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Agreement status</label>
                    <select id="status" name="status" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none">
                        <option value="Active" <%= agreement.status === 'Active' ? 'selected' : '' %>>Active</option>
                        <option value="Ended" <%= agreement.status === 'Ended' ? 'selected' : '' %>>Ended</option>
                    </select>
                </div>

                <div>
                    <label for="agreement_doc_url" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Document File URL (Optional)</label>
                    <input type="url" id="agreement_doc_url" name="agreement_doc_url" value="<%= agreement.agreement_doc_url || '' %>"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none placeholder-zinc-700">
                </div>
            </div>

            <div>
                <label for="notes" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Audit Remarks &amp; Token Notes (Optional)</label>
                <textarea id="notes" name="notes" rows="2" class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none"><%= agreement.notes %></textarea>
            </div>

            <div class="pt-4 border-t border-[#1F1F1F] flex justify-end gap-3">
                <button type="button" onclick="history.back()" class="px-4 py-2 bg-[#1A1A1A] hover:bg-[#2A2A2A] text-zinc-400 hover:text-white border border-[#262626] text-xs font-semibold rounded-md transition-all">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-white text-black hover:bg-zinc-200 text-xs font-bold rounded-md transition-all">
                    Update Agreement
                </button>
            </div>
        </form>
    </div>
</main>

<%- include('../partials/footer') %>
