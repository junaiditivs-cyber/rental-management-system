<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<%
    const canViewSmartEntry = typeof can === 'function' && can('view_smart_entry');
    const canAddProperties = typeof can === 'function' && can('add_properties');
    const canAddCities = typeof can === 'function' && can('add_cities');
    const canViewCities = typeof can === 'function' && can('view_cities');
    const canViewLogs = typeof can === 'function' && can('view_logs');

    const expected = Number(overallStats.expected || 0);
    const received = Number(overallStats.received || 0);
    const pending = Number(overallStats.pending || 0);
    const advanceReceived = Number(overallStats.advanceReceived || 0);
    const advanceThisMonth = Number(overallStats.advanceThisMonth || 0);

    const totalUnits = Number(overallStats.totalUnits || 0);
    const rentedUnits = Number(overallStats.rentedUnits || 0);
    const vacantUnits = Number(overallStats.vacantUnits || 0);
    const vacancyRate = Number(overallStats.vacancyRate || 0);

    const receivedPercent = expected > 0 ? Math.min(100, Math.round((received / expected) * 100)) : 0;
    const pendingPercent = expected > 0 ? Math.min(100, Math.round((pending / expected) * 100)) : 0;
%>

<main class="flex-1 flex flex-col h-full overflow-hidden bg-[#080A0F]">

    <!-- Header -->
    <header class="min-h-16 border-b border-slate-800/80 bg-[#0B0E14] px-6 lg:px-8 py-4 flex flex-col xl:flex-row xl:items-center xl:justify-between gap-4 shrink-0">
        <div>
            <div class="flex items-center gap-2 text-xs text-slate-500 mb-1">
                <span>Overview</span>
                <span class="text-slate-700">/</span>
                <span class="text-slate-300 font-semibold">Main Administrative Dashboard</span>
            </div>
            <h1 class="text-white text-xl font-bold tracking-tight">
                Rental Portfolio Control Center
            </h1>
        </div>

        <div class="flex flex-wrap items-center gap-3">
            <% if (canViewSmartEntry) { %>
                <a href="/smart-entry" class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-xl shadow-sm transition-all active:scale-[0.98]">
                    <span>⚡</span>
                    <span>Smart Entry</span>
                </a>
            <% } %>

            <% if (canAddProperties) { %>
                <a href="/properties/add" class="inline-flex items-center justify-center px-4 py-2 bg-slate-900 hover:bg-slate-800 border border-slate-700 text-slate-200 text-xs font-bold rounded-xl transition-all active:scale-[0.98]">
                    + Add Property
                </a>
            <% } %>

            <div class="hidden md:block w-px h-6 bg-slate-800"></div>

            <div class="inline-flex items-center gap-2 px-3 py-2 bg-slate-950 border border-slate-800 rounded-xl">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                <span class="text-[11px] text-slate-400 font-mono">
                    <%= new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %> PKT
                </span>
            </div>
        </div>
    </header>

    <div class="p-5 lg:p-8 flex-1 overflow-y-auto space-y-7">

        <% if (locals.success_msg) { %>
            <div class="p-4 bg-emerald-950/30 border border-emerald-500/20 text-emerald-300 text-xs rounded-2xl flex items-center justify-between shadow-sm">
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
                    <span><%= success_msg %></span>
                </div>
                <button onclick="this.parentElement.remove()" class="text-emerald-500 hover:text-emerald-300 font-bold text-sm">&times;</button>
            </div>
        <% } %>

        <!-- Executive Summary -->
        <section class="grid grid-cols-1 xl:grid-cols-12 gap-5">
            <div class="xl:col-span-8 bg-[#10141D] border border-slate-800 rounded-3xl p-6 shadow-sm">
                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
                    <div>
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-blue-500/10 border border-blue-500/20 rounded-full text-[11px] text-blue-300 font-bold mb-4">
                            <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
                            Live Business Overview
                        </div>

                        <h2 class="text-2xl lg:text-3xl font-bold text-white tracking-tight">
                            Assalam-o-Alaikum, JUNAID
                        </h2>

                        <p class="text-slate-400 text-sm mt-2 max-w-2xl leading-relaxed">
                            Real-time overview of rent collection, property occupancy, city performance and recent system activity across your rental portfolio.
                        </p>
                    </div>

                    <div class="grid grid-cols-2 gap-3 min-w-[260px]">
                        <div class="bg-[#0B0E14] border border-slate-800 rounded-2xl p-4">
                            <div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold">Total Units</div>
                            <div class="text-2xl text-white font-bold mt-1"><%= totalUnits %></div>
                        </div>

                        <div class="bg-[#0B0E14] border border-slate-800 rounded-2xl p-4">
                            <div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold">Occupied</div>
                            <div class="text-2xl text-emerald-400 font-bold mt-1"><%= rentedUnits %></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="xl:col-span-4 bg-[#10141D] border border-slate-800 rounded-3xl p-6 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <div>
                        <div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold">Collection Health</div>
                        <div class="text-white text-xl font-bold mt-1"><%= receivedPercent %>% Received</div>
                    </div>
                    <div class="w-11 h-11 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 font-bold">
                        %
                    </div>
                </div>

                <div class="h-2 bg-slate-800 rounded-full overflow-hidden">
                    <div id="collection-health-bar" class="h-full w-0 bg-emerald-500 rounded-full transition-all duration-500" data-progress="<%= receivedPercent %>"></div>
                </div>

                <div class="flex justify-between text-[11px] text-slate-500 mt-3 font-mono">
                    <span>Received ₨ <%= received.toLocaleString() %></span>
                    <span>Expected ₨ <%= expected.toLocaleString() %></span>
                </div>
            </div>
        </section>

        <!-- KPI Cards -->
        <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-5">
            <div class="bg-[#10141D] border border-slate-800 rounded-3xl p-5 shadow-sm hover:border-slate-600 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="text-[10px] font-bold text-slate-500 tracking-wider uppercase">Expected Monthly Rent</div>
                    <div class="w-10 h-10 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 text-sm font-bold">₨</div>
                </div>
                <div class="text-3xl font-bold text-white mt-4 tracking-tight">₨ <%= expected.toLocaleString() %></div>
                <div class="text-[11px] text-slate-500 mt-3 font-mono">Total rent scheduled for current month</div>
            </div>

            <div class="bg-[#10141D] border border-slate-800 rounded-3xl p-5 shadow-sm hover:border-emerald-700 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="text-[10px] font-bold text-emerald-500 tracking-wider uppercase">Received Rent</div>
                    <div class="w-10 h-10 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 text-sm font-bold">✓</div>
                </div>
                <div class="text-3xl font-bold text-emerald-400 mt-4 tracking-tight">₨ <%= received.toLocaleString() %></div>
                <div class="text-[11px] text-emerald-500/80 mt-3 font-mono"><%= receivedPercent %>% of expected rent collected</div>
            </div>

            <div class="bg-[#10141D] border border-slate-800 rounded-3xl p-5 shadow-sm hover:border-amber-700 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="text-[10px] font-bold text-amber-500 tracking-wider uppercase">Outstanding Rent</div>
                    <div class="w-10 h-10 rounded-2xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400 text-sm font-bold">!</div>
                </div>
                <div class="text-3xl font-bold text-amber-400 mt-4 tracking-tight">₨ <%= pending.toLocaleString() %></div>
                <div class="text-[11px] text-amber-500/80 mt-3 font-mono"><%= pendingPercent %>% pending from current cycle</div>
            </div>

            <div class="bg-[#10141D] border border-slate-800 rounded-3xl p-5 shadow-sm hover:border-violet-700 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="text-[10px] font-bold text-violet-400 tracking-wider uppercase">Advance Payments</div>
                    <div class="w-10 h-10 rounded-2xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center text-violet-300 text-sm font-bold">A</div>
                </div>
                <div class="text-3xl font-bold text-violet-300 mt-4 tracking-tight">₨ <%= advanceReceived.toLocaleString() %></div>
                <div class="text-[11px] text-violet-400/80 mt-3 font-mono">
                    This month: ₨ <%= advanceThisMonth.toLocaleString() %>
                </div>
            </div>

            <div class="bg-[#10141D] border border-slate-800 rounded-3xl p-5 shadow-sm hover:border-slate-600 transition-colors">
                <div class="flex items-center justify-between">
                    <div class="text-[10px] font-bold text-slate-500 tracking-wider uppercase">Vacancy Ratio</div>
                    <div class="w-10 h-10 rounded-2xl bg-slate-500/10 border border-slate-500/20 flex items-center justify-center text-slate-300 text-sm font-bold">%</div>
                </div>
                <div class="text-3xl font-bold text-white mt-4 tracking-tight"><%= vacancyRate.toFixed(1) %>%</div>
                <div class="text-[11px] text-slate-500 mt-3 font-mono">
                    <%= vacantUnits %> vacant / <%= totalUnits %> total units
                </div>
            </div>
        </section>

        <!-- Cities Summary -->
        <section class="bg-[#10141D] border border-slate-800 rounded-3xl shadow-sm overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-800 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                <div>
                    <h2 class="text-white text-base font-bold">Portfolio Cities</h2>
                    <p class="text-slate-500 text-xs mt-1">City wise properties, unit occupancy and rent collection summary.</p>
                </div>

                <% if (canAddCities) { %>
                    <a href="/cities/add" class="inline-flex items-center justify-center px-3 py-2 bg-slate-900 border border-slate-700 text-slate-300 text-xs font-bold rounded-xl hover:bg-slate-800 hover:text-white transition-colors">
                        + Add New City
                    </a>
                <% } %>
            </div>

            <div class="p-5">
                <% if (citiesData && citiesData.length > 0) { %>
                    <div class="grid grid-cols-1 xl:grid-cols-3 gap-5">
                        <% citiesData.forEach(city => { %>
                            <div
                                class="bg-[#0B0E14] border border-slate-800 rounded-3xl overflow-hidden hover:border-blue-500/40 transition-all <%= canViewCities ? 'cursor-pointer' : '' %>"
                                <% if (canViewCities) { %> onclick="window.location.href='/cities/<%= city.id %>'" <% } %>
                            >
                                <div class="p-5">
                                    <div class="flex items-start justify-between gap-4 mb-5">
                                        <div>
                                            <h3 class="text-white text-lg font-bold capitalize tracking-tight"><%= city.name %></h3>
                                            <p class="text-slate-500 text-xs mt-1"><%= city.province %></p>
                                        </div>

                                        <span class="px-2.5 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] uppercase tracking-wider font-bold rounded-lg">
                                            <%= Number(city.propertyCount || 0) %> Properties
                                        </span>
                                    </div>

                                    <div class="grid grid-cols-2 gap-3">
                                        <div class="border border-slate-800 bg-[#10141D] rounded-2xl p-3">
                                            <div class="text-[9px] text-slate-500 uppercase font-bold tracking-wider">Total Units</div>
                                            <div class="text-white text-lg font-bold mt-1"><%= Number(city.unitCount || 0) %></div>
                                        </div>

                                        <div class="border border-slate-800 bg-[#10141D] rounded-2xl p-3">
                                            <div class="text-[9px] text-slate-500 uppercase font-bold tracking-wider">Rented</div>
                                            <div class="text-emerald-400 text-lg font-bold mt-1"><%= Number(city.rentedCount || 0) %></div>
                                        </div>

                                        <div class="border border-slate-800 bg-[#10141D] rounded-2xl p-3">
                                            <div class="text-[9px] text-slate-500 uppercase font-bold tracking-wider">Vacant</div>
                                            <div class="text-red-400 text-lg font-bold mt-1"><%= Number(city.vacantCount || 0) %></div>
                                        </div>

                                        <div class="border border-slate-800 bg-[#10141D] rounded-2xl p-3">
                                            <div class="text-[9px] text-slate-500 uppercase font-bold tracking-wider">Expected</div>
                                            <div class="text-slate-200 text-lg font-bold mt-1">₨ <%= (Number(city.expectedRent || 0) / 1000).toFixed(0) %>k</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="px-5 py-4 border-t border-slate-800 bg-[#10141D] flex justify-between items-center">
                                    <span class="text-slate-500 text-xs font-semibold">Cash Collection</span>
                                    <span class="text-white text-sm font-bold font-mono">₨ <%= Number(city.receivedRent || 0).toLocaleString() %></span>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="p-10 text-center text-slate-500 text-sm">
                        <p>No cities available. Add your first city to begin portfolio operations.</p>

                        <% if (canAddCities) { %>
                            <a href="/cities/add" class="inline-flex mt-4 px-4 py-2 bg-white text-black rounded-xl text-xs font-bold hover:bg-slate-200">
                                Add City
                            </a>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </section>

        <!-- Recent Activity Logs -->
        <section class="bg-[#10141D] border border-slate-800 rounded-3xl shadow-sm overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-800 flex items-center justify-between gap-3">
                <div>
                    <h3 class="text-white text-base font-bold">Recent Activity</h3>
                    <p class="text-slate-500 text-xs mt-1">Latest administrative and system actions.</p>
                </div>

                <% if (canViewLogs) { %>
                    <a href="/logs" class="text-xs text-slate-400 hover:text-white font-bold">
                        View All Logs
                    </a>
                <% } %>
            </div>

            <div class="divide-y divide-slate-800">
                <% if (activityLogs && activityLogs.length > 0) { %>
                    <% activityLogs.slice(0, 5).forEach(log => { %>
                        <div class="px-6 py-4 flex flex-col md:flex-row md:items-center md:justify-between gap-3 hover:bg-slate-900/50 transition-colors">
                            <div class="flex items-start md:items-center gap-3">
                                <span class="px-2.5 py-1 bg-slate-900 border border-slate-700 rounded-lg text-[10px] text-slate-400 font-mono uppercase font-bold">
                                    <%= log.action %>
                                </span>
                                <span class="text-slate-300 text-xs leading-relaxed"><%= log.details %></span>
                            </div>

                            <span class="text-slate-500 text-[11px] font-mono shrink-0">
                                <%= new Date(log.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                            </span>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="p-8 text-center text-slate-500 text-xs">No active logs saved.</div>
                <% } %>
            </div>
        </section>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const collectionBar = document.getElementById('collection-health-bar');

        if (collectionBar) {
            const rawProgress = Number(collectionBar.dataset.progress || 0);
            const safeProgress = Math.min(100, Math.max(0, rawProgress));

            collectionBar.style.width = safeProgress + '%';
        }
    });
</script>
<%- include('partials/footer') %>