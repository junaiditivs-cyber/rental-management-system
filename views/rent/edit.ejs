<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Rent Ledger &gt; <span class="text-zinc-200">Edit Rent / Installment Details</span></div>
        <a href="javascript:history.back()" class="text-xs text-zinc-400 hover:text-white transition-colors">&larr; Cancel</a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto max-w-2xl space-y-6 font-sans">
        <div>
            <h1 class="text-white text-lg font-bold tracking-tight">Edit Installment / Rent Payment</h1>
            <p class="text-zinc-500 text-xs mt-1">Configure historical collection details. Arrears and statuses will recompute, or you can supply custom statuses.</p>
        </div>

        <% if (locals.error_msg) { %>
            <div class="p-4 bg-red-950/30 border border-red-500/20 text-red-400 text-xs rounded-xl flex items-center justify-between shadow-md">
                <div class="flex items-center gap-2">
                    <span>⚠️</span>
                    <span><%= error_msg %></span>
                </div>
                <button onclick="this.parentElement.remove()" class="text-red-500 font-bold">&times;</button>
            </div>
        <% } %>

        <form action="/rent/<%= payment.id %>/edit" method="POST" class="bg-[#111111] border border-[#262626] p-6 rounded-xl space-y-4">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">MAPPED TENANT</label>
                    <input type="text" readonly value="<%= tenant ? tenant.name : 'Unknown' %>" 
                           class="w-full px-3 py-2 bg-zinc-950 border border-zinc-90 w-full rounded-md text-zinc-400 text-sm focus:outline-none cursor-not-allowed">
                </div>

                <div>
                    <label class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">CORRESPONDING UNIT</label>
                    <input type="text" readonly value="<%= unit ? unit.name : 'Unknown' %>" 
                           class="w-full px-3 py-2 bg-zinc-950 border border-zinc-90 w-full rounded-md text-zinc-400 text-sm focus:outline-none cursor-not-allowed">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-[#1F1F1F] pt-4">
                <div>
                    <label for="rent_month" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Rent Month Name</label>
                    <select id="rent_month" name="rent_month" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none font-mono">
                        <% const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"]; %>
                        <% months.forEach((m, idx) => { %>
                            <option value="<%= idx + 1 %>" <%= payment.rent_month === idx + 1 ? 'selected' : '' %>><%= m %></option>
                        <% }) %>
                    </select>
                </div>

                <div>
                    <label for="rent_year" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Rent Year</label>
                    <select id="rent_year" name="rent_year" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none font-mono">
                        <% for(let y=2025; y<=2028; y++) { %>
                            <option value="<%= y %>" <%= payment.rent_year === y ? 'selected' : '' %>><%= y %></option>
                        <% } %>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 border-t border-[#1F1F1F] pt-4">
                <div>
                    <label for="total_rent" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Due Installment Rate (PKR)</label>
                    <input type="number" id="total_rent" name="total_rent" required value="<%= payment.total_rent %>" oninput="calculateArrears()"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none font-mono">
                </div>

                <div>
                    <label for="paid_amount" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5 font-bold text-emerald-400">Paid Amount (PKR)</label>
                    <input type="number" id="paid_amount" name="paid_amount" required min="0" value="<%= payment.paid_amount %>" oninput="calculateArrears()"
                           class="w-full px-3 py-2 bg-[#161616] border border-blue-500/30 rounded-md text-white text-sm focus:outline-none focus:border-blue-500 font-mono">
                </div>

                <div>
                    <label for="pending_amount" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5 text-red-400">Arrears/Pending Amount (PKR)</label>
                    <input type="number" id="pending_amount" name="pending_amount" required value="<%= payment.pending_amount %>" readonly
                           class="w-full px-3 py-2 bg-zinc-950 border border-zinc-900 rounded-md text-red-400 text-sm focus:outline-none cursor-not-allowed font-mono">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label for="payment_method" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Payment Method</label>
                    <select id="payment_method" name="payment_method" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none">
                        <option value="Cash" <%= payment.payment_method === 'Cash' ? 'selected' : '' %>>Cash Handover</option>
                        <option value="Bank" <%= payment.payment_method === 'Bank' ? 'selected' : '' %>>Bank Wire</option>
                        <option value="EasyPaisa" <%= payment.payment_method === 'EasyPaisa' ? 'selected' : '' %>>EasyPaisa</option>
                        <option value="JazzCash" <%= payment.payment_method === 'JazzCash' ? 'selected' : '' %>>JazzCash</option>
                        <option value="Other" <%= payment.payment_method === 'Other' ? 'selected' : '' %>>Other</option>
                    </select>
                </div>

                <div>
                    <label for="payment_date" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Date Received</label>
                    <input type="date" id="payment_date" name="payment_date" required value="<%= payment.payment_date %>"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none font-mono">
                </div>

                <div>
                    <label for="status" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Payment Status Override</label>
                    <select id="status" name="status" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none">
                        <option value="Paid" <%= payment.status === 'Paid' ? 'selected' : '' %>>Paid (Settled)</option>
                        <option value="Partial" <%= payment.status === 'Partial' ? 'selected' : '' %>>Partial payment</option>
                        <option value="Pending" <%= payment.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                        <option value="Overdue" <%= payment.status === 'Overdue' ? 'selected' : '' %>>Overdue</option>
                    </select>
                </div>
            </div>

            <div>
                <label for="notes" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Remarks / Ledger Notes</label>
                <textarea id="notes" name="notes" rows="2" class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none"><%= payment.notes %></textarea>
            </div>

            <div class="pt-4 border-t border-[#1F1F1F] flex justify-end gap-3">
                <button type="button" onclick="history.back()" class="px-4 py-2 bg-[#1A1A1A] hover:bg-[#2A2A2A] text-zinc-400 hover:text-white border border-[#262626] text-xs font-semibold rounded-md transition-all">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-white text-black hover:bg-zinc-200 text-xs font-bold rounded-md transition-all">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</main>

<script>
    function calculateArrears() {
        const required = parseInt(document.getElementById('total_rent').value || '0', 10);
        const collected = parseInt(document.getElementById('paid_amount').value || '0', 10);
        const arrears = Math.max(0, required - collected);
        document.getElementById('pending_amount').value = arrears;

        const statusSelect = document.getElementById('status');
        if (arrears === 0) {
            statusSelect.value = 'Paid';
        } else if (collected > 0) {
            statusSelect.value = 'Partial';
        } else {
            statusSelect.value = 'Overdue';
        }
    }
</script>

<%- include('../partials/footer') %>
