<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Rent Ledger &gt; <span class="text-zinc-200">Collect Monthly Rent</span></div>
        <a href="javascript:history.back()" class="text-xs text-zinc-400 hover:text-white transition-colors">&larr; Cancel</a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto max-w-2xl space-y-6">
        <div>
            <h1 class="text-white text-lg font-bold tracking-tight">Record Monthly Rent Payment</h1>
            <p class="text-zinc-500 text-xs mt-1">Submit collected cash, bank transfers, or mobile wallet deposits. Arrears or partial values are computed instantly.</p>
        </div>

        <form action="/rent/collect" method="POST" class="bg-[#111111] border border-[#262626] p-6 rounded-xl space-y-4">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="agreement_id_select" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Active Agreement Node</label>
                    <select id="agreement_id_select" name="agreement_id" required onchange="applyAgreementDetails(this.value)"
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        <option value="">-- Choose Unit Lease --</option>
                        <% agreements.forEach(ag => { %>
                            <option value="<%= ag.id %>" <%= typeof p_unit_id !== 'undefined' && p_unit_id === ag.unit_id ? 'selected' : '' %> data-rent="<%= ag.monthly_rent %>" data-tenant="<%= ag.tenant_id %>" data-unit="<%= ag.unit_id %>">
                                <%= ag.unit_name %> (Tenant: <%= ag.tenant_name %> &bull; Rate: ₨ <%= ag.monthly_rent.toLocaleString() %>)
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label for="rent_month" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Rent Month</label>
                        <select id="rent_month" name="rent_month" required
                                class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all font-mono">
                            <% const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"]; %>
                            <% months.forEach((m, idx) => { %>
                                <option value="<%= idx + 1 %>" <%= new Date().getMonth() + 1 === idx + 1 ? 'selected' : '' %>><%= m %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div>
                        <label for="rent_year" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Year</label>
                        <select id="rent_year" name="rent_year" required
                                class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all font-mono">
                            <option value="2025" <%= new Date().getFullYear() === 2025 ? 'selected' : '' %>>2025</option>
                            <option value="2026" <%= new Date().getFullYear() === 2026 ? 'selected' : '' %>>2026</option>
                            <option value="2027" <%= new Date().getFullYear() === 2027 ? 'selected' : '' %>>2027</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 border-t border-[#1F1F1F] pt-4">
                <div>
                    <label for="total_rent" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Required Monthly Rate (PKR)</label>
                    <input type="number" id="total_rent" name="total_rent" required readonly placeholder="0"
                           class="w-full px-3 py-2 bg-zinc-950 border border-zinc-900 rounded-md text-zinc-400 text-sm focus:outline-none cursor-not-allowed font-mono">
                </div>

                <div>
                    <label for="paid_amount" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5 font-bold text-emerald-400">Paid Amount Collected (PKR)</label>
                    <input type="number" id="paid_amount" name="paid_amount" required min="0" placeholder="0" oninput="calculateArrears()"
                           class="w-full px-3 py-2 bg-[#161616] border border-blue-500/30 rounded-md text-white text-sm focus:outline-none focus:border-blue-500 font-mono">
                </div>

                <div>
                    <label for="pending_amount" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5 text-red-400">Outstanding Residual (PKR)</label>
                    <input type="number" id="pending_amount" name="pending_amount" required readonly placeholder="0"
                           class="w-full px-3 py-2 bg-zinc-950 border border-zinc-904 rounded-md text-red-400 text-sm focus:outline-none cursor-not-allowed font-mono">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="payment_method" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Collection Gateway / Channel</label>
                    <select id="payment_method" name="payment_method" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        <option value="Cash">Handheld Cash</option>
                        <option value="Bank">Bank Deposit / IBFT</option>
                        <option value="EasyPaisa">EasyPaisa Wallet</option>
                        <option value="JazzCash">JazzCash Wallet</option>
                        <option value="Other">Other Gateway</option>
                    </select>
                </div>

                <div>
                    <label for="payment_date" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Collection Date</label>
                    <input type="date" id="payment_date" name="payment_date" required value="<%= new Date().toISOString().split('T')[0] %>"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all font-mono">
                </div>
            </div>

            <div>
                <label for="payment_proof_url" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Deposit Slip Photo / Receipt Link (Optional)</label>
                <input type="url" id="payment_proof_url" name="payment_proof_url" placeholder="https://example.com/slip-attachment.jpg"
                       class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-700 focus:outline-none focus:border-blue-500/80 transition-all">
                <span class="text-[10px] text-zinc-500 mt-1 block">Proof image is optional. Leaving blank will not block submission.</span>
            </div>

            <div>
                <label for="notes" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Collection Notes (Optional)</label>
                <textarea id="notes" name="notes" rows="2" placeholder="Bank transaction keys or promise note dates if partial..."
                          class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all"></textarea>
            </div>

            <div class="pt-4 border-t border-[#1F1F1F] flex justify-end gap-3">
                <button type="button" onclick="history.back()" class="px-4 py-2 bg-[#1A1A1A] hover:bg-[#2A2A2A] text-zinc-400 hover:text-white border border-[#262626] text-xs font-semibold rounded-md transition-all">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-white text-black hover:bg-zinc-200 text-xs font-bold rounded-md transition-all">
                    Record Payment
                </button>
            </div>
        </form>
    </div>
</main>

<script>
    function applyAgreementDetails(agreementId) {
        if (!agreementId) return;
        const selectNode = document.getElementById('agreement_id_select');
        const selectedOpt = selectNode.options[selectNode.selectedIndex];
        
        const rentRate = parseInt(selectedOpt.getAttribute('data-rent') || '0', 10);
        document.getElementById('total_rent').value = rentRate;
        document.getElementById('paid_amount').value = rentRate; // Preset full paid as default
        calculateArrears();
    }

    function calculateArrears() {
        const required = parseInt(document.getElementById('total_rent').value || '0', 10);
        const collected = parseInt(document.getElementById('paid_amount').value || '0', 10);
        
        const arrears = Math.max(0, required - collected);
        document.getElementById('pending_amount').value = arrears;
    }

    // Run first triggers once page mounts
    document.addEventListener('DOMContentLoaded', () => {
        applyAgreementDetails(document.getElementById('agreement_id_select').value);
    });
</script>

<%- include('../partials/footer') %>
