<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Overview &gt; <span class="text-zinc-200">Sectors / Areas</span></div>
        <a href="/areas/add" class="px-3 py-1.5 bg-white text-black text-xs font-semibold rounded-md hover:bg-zinc-200 transition-colors">
            + Add Area
        </a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto space-y-6">
        <div>
            <h1 class="text-white text-lg font-bold tracking-tight">Areas &amp; Sectors</h1>
            <p class="text-zinc-500 text-xs mt-1">Manage physical sectors mapped against major municipal territories of Pakistan.</p>
        </div>

        <div class="bg-[#111111] border border-[#262626] rounded-xl overflow-hidden shadow-lg">
            <table class="w-full text-left border-collapse font-sans">
                <thead>
                    <tr class="border-b border-[#1F1F1F] bg-[#161616] text-[10px] font-bold text-zinc-500 uppercase tracking-wider">
                        <th class="p-4">Sector Name</th>
                        <th class="p-4">Municipal City</th>
                        <th class="p-4">Linked Properties</th>
                        <th class="p-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#1F1F1F] text-sm text-zinc-300">
                    <% if (areas && areas.length > 0) { %>
                        <% areas.forEach(area => { %>
                            <tr class="hover:bg-[#161616]/30 transition-colors">
                                <td class="p-4 font-semibold text-white"><%= area.name %></td>
                                <td class="p-4 text-zinc-400">
                                    <a href="/cities/<%= area.city_id %>" class="hover:text-blue-400 underline decoration-dotted">
                                        <%= area.city_name %>
                                    </a>
                                </td>
                                <td class="p-4 font-mono text-xs text-zinc-500"><%= area.propertyCount %> Property(s) linked</td>
                                <td class="p-4 text-right space-x-2">
                                    <a href="/areas/<%= area.id %>/edit" class="text-xs text-zinc-400 hover:text-white bg-[#1A1A1A] border border-[#262626] px-2.5 py-1 rounded transition-colors inline-block">
                                        Edit
                                    </a>
                                    
                                    <% if (area.propertyCount === 0) { %>
                                        <form action="/areas/<%= area.id %>/delete" method="POST" class="inline-block" onsubmit="return confirm('Do you want to delete this empty sector?');">
                                            <button type="submit" class="text-xs text-red-400 hover:text-red-300 bg-red-950/20 border border-red-900/30 px-2.5 py-1 rounded transition-colors inline-block">
                                                Delete
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <button disabled class="text-xs text-zinc-650 bg-zinc-900 border border-[#1F1F1F] px-2.5 py-1 rounded cursor-not-allowed inline-block" title="Lock is active as properties are mapped">
                                            Locked
                                        </button>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="p-8 text-center text-zinc-500">
                                No sectors configured. Click Add Area to map a sector.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
