<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div>
            <h1 class="text-white text-lg font-bold">Add User</h1>
            <p class="text-zinc-500 text-xs">Create a login user for assigned property access.</p>
        </div>
        <a href="/users" class="px-4 py-2 bg-[#1C1C1E] text-zinc-300 text-xs font-semibold rounded border border-[#2E2E30]">
            Back
        </a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto">
        <form action="/users/add" method="POST" class="max-w-xl bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-5">
            <% if (error_msg) { %>
                <div class="bg-red-950/30 border border-red-700 text-red-300 px-4 py-3 rounded text-sm">
                    <%= error_msg %>
                </div>
            <% } %>

            <div>
                <label class="block text-xs font-bold text-zinc-400 uppercase mb-2">Full Name</label>
                <input type="text" name="full_name" class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded text-white text-sm" placeholder="e.g. Property Manager">
            </div>

            <div>
                <label class="block text-xs font-bold text-zinc-400 uppercase mb-2">Username</label>
                <input type="text" name="username" required class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded text-white text-sm" placeholder="e.g. manager1">
            </div>

            <div>
                <label class="block text-xs font-bold text-zinc-400 uppercase mb-2">Password</label>
                <input type="text" name="password" required class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded text-white text-sm" placeholder="Set login password">
            </div>

            <div>
                <label class="block text-xs font-bold text-zinc-400 uppercase mb-2">Role</label>
                <select name="role" class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded text-white text-sm">
                    <option value="User">User</option>
                    <option value="Super Admin">Super Admin</option>
                </select>
            </div>

            <button type="submit" class="px-5 py-2 bg-white text-black text-sm font-bold rounded hover:bg-zinc-200">
                Create User
            </button>
        </form>
    </div>
</main>

<%- include('../partials/footer') %>