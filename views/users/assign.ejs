<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div>
            <h1 class="text-white text-lg font-bold">Assign User Access</h1>
            <p class="text-zinc-500 text-xs">Assign properties and permissions to this user.</p>
        </div>

        <a href="/users" class="px-4 py-2 bg-[#1C1C1E] text-zinc-300 text-xs font-semibold rounded border border-[#2E2E30] hover:text-white transition-colors">
            Back to Users
        </a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto">
        <form action="/users/<%= user.id %>/assign" method="POST" class="space-y-8">

            <!-- User Info Card -->
            <section class="bg-[#111111] border border-[#262626] rounded-xl p-6">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h2 class="text-white text-xl font-bold"><%= user.full_name || user.username %></h2>
                        <p class="text-zinc-500 text-xs font-mono mt-1">
                            Username: <%= user.username %>
                        </p>
                        <p class="text-zinc-500 text-xs mt-1">
                            Role: 
                            <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase <%= user.role === 'Super Admin' ? 'bg-blue-950/40 text-blue-300 border border-blue-700/40' : 'bg-zinc-900 text-zinc-300 border border-zinc-700' %>">
                                <%= user.role || 'User' %>
                            </span>
                        </p>
                    </div>

                    <% if (user.role === 'Super Admin') { %>
                        <div class="bg-blue-950/20 border border-blue-800/40 text-blue-300 text-xs px-4 py-3 rounded-lg max-w-sm">
                            Super Admin already has full access. Permissions below are mainly for normal users.
                        </div>
                    <% } %>
                </div>
            </section>

            <!-- Property Access -->
            <section class="bg-[#111111] border border-[#262626] rounded-xl overflow-hidden">
                <div class="px-6 py-4 border-b border-[#262626] flex items-center justify-between gap-4">
                    <div>
                        <h3 class="text-white font-bold">Property Access</h3>
                        <p class="text-zinc-500 text-xs mt-1">User will only see selected properties and their related units, tenants, rent and advance records.</p>
                    </div>

                    <div class="flex gap-2">
                        <button type="button" onclick="togglePropertyAccess(true)" class="px-3 py-1.5 bg-[#1C1C1E] text-zinc-300 border border-[#2E2E30] rounded text-xs font-semibold hover:text-white">
                            Select All
                        </button>
                        <button type="button" onclick="togglePropertyAccess(false)" class="px-3 py-1.5 bg-[#1C1C1E] text-zinc-300 border border-[#2E2E30] rounded text-xs font-semibold hover:text-white">
                            Clear
                        </button>
                    </div>
                </div>

                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                        <% properties.forEach(property => { %>
                            <label class="block bg-[#161616] border border-[#262626] rounded-lg p-4 cursor-pointer hover:border-blue-500/50 transition-colors">
                                <div class="flex items-start gap-3">
                                    <input 
                                        type="checkbox" 
                                        name="property_ids" 
                                        value="<%= property.id %>" 
                                        <%= property.isAssigned ? 'checked' : '' %>
                                        class="property-checkbox mt-1"
                                    >

                                    <div>
                                        <div class="text-white text-sm font-bold"><%= property.name %></div>
                                        <div class="text-zinc-500 text-xs mt-1">
                                            <%= property.city_name %> • <%= property.area_name %>
                                        </div>
                                        <div class="text-zinc-500 text-[10px] uppercase mt-1">
                                            <%= property.property_type || 'Property' %>
                                        </div>
                                    </div>
                                </div>
                            </label>
                        <% }) %>

                        <% if (!properties || properties.length === 0) { %>
                            <div class="col-span-full text-zinc-500 text-sm text-center py-8">
                                No properties available to assign.
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>

            <!-- Permissions Access -->
            <section class="bg-[#111111] border border-[#262626] rounded-xl overflow-hidden">
                <div class="px-6 py-4 border-b border-[#262626] flex items-center justify-between gap-4">
                    <div>
                        <h3 class="text-white font-bold">Page / Button / Action Permissions</h3>
                        <p class="text-zinc-500 text-xs mt-1">Only selected pages, buttons and actions will be allowed for this user.</p>
                    </div>

                    <div class="flex gap-2">
                        <button type="button" onclick="togglePermissionAccess(true)" class="px-3 py-1.5 bg-[#1C1C1E] text-zinc-300 border border-[#2E2E30] rounded text-xs font-semibold hover:text-white">
                            Select All
                        </button>
                        <button type="button" onclick="togglePermissionAccess(false)" class="px-3 py-1.5 bg-[#1C1C1E] text-zinc-300 border border-[#2E2E30] rounded text-xs font-semibold hover:text-white">
                            Clear
                        </button>
                    </div>
                </div>

                <div class="p-6 space-y-6">
                    <% permissionGroups.forEach(group => { %>
                        <div class="bg-[#161616] border border-[#262626] rounded-xl p-5">
                            <div class="flex items-center justify-between gap-4 mb-4">
                                <h4 class="text-white font-bold text-sm"><%= group.title %></h4>

                                <div class="flex gap-2">
                                    <button type="button" onclick="toggleGroupPermissions('<%= group.title.replace(/[^a-zA-Z0-9]/g, '-') %>', true)" class="px-2.5 py-1 bg-[#111111] text-zinc-400 border border-[#2E2E30] rounded text-[10px] font-bold hover:text-white">
                                        All
                                    </button>
                                    <button type="button" onclick="toggleGroupPermissions('<%= group.title.replace(/[^a-zA-Z0-9]/g, '-') %>', false)" class="px-2.5 py-1 bg-[#111111] text-zinc-400 border border-[#2E2E30] rounded text-[10px] font-bold hover:text-white">
                                        None
                                    </button>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                                <% group.permissions.forEach(permission => { %>
                                    <label class="flex items-center gap-3 bg-[#0A0A0A] border border-[#262626] rounded-lg px-3 py-2.5 cursor-pointer hover:border-blue-500/40 transition-colors">
                                        <input 
                                            type="checkbox" 
                                            name="permission_keys" 
                                            value="<%= permission.key %>"
                                            data-group="<%= group.title.replace(/[^a-zA-Z0-9]/g, '-') %>"
                                            <%= assignedPermissionKeys && assignedPermissionKeys.includes(permission.key) ? 'checked' : '' %>
                                            class="permission-checkbox"
                                        >
                                        <span class="text-zinc-300 text-xs font-semibold"><%= permission.label %></span>
                                    </label>
                                <% }) %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </section>

            <!-- Save Bar -->
            <div class="sticky bottom-0 bg-[#0A0A0A]/95 border border-[#262626] rounded-xl p-4 flex items-center justify-between gap-4">
                <div class="text-zinc-500 text-xs">
                    After saving, user should logout/login again to refresh access.
                </div>

                <button type="submit" class="px-6 py-2.5 bg-white text-black text-sm font-bold rounded hover:bg-zinc-200 transition-colors">
                    Save User Access
                </button>
            </div>
        </form>
    </div>
</main>

<script>
    function togglePropertyAccess(checked) {
        document.querySelectorAll('.property-checkbox').forEach(function(box) {
            box.checked = checked;
        });
    }

    function togglePermissionAccess(checked) {
        document.querySelectorAll('.permission-checkbox').forEach(function(box) {
            box.checked = checked;
        });
    }

    function toggleGroupPermissions(groupName, checked) {
        document.querySelectorAll('.permission-checkbox[data-group="' + groupName + '"]').forEach(function(box) {
            box.checked = checked;
        });
    }
</script>

<%- include('../partials/footer') %>