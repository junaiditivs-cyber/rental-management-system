<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div>
            <h1 class="text-white text-lg font-bold">Users & Access</h1>
            <p class="text-zinc-500 text-xs">Create users and assign property access.</p>
        </div>
        <a href="/users/add" class="px-4 py-2 bg-white text-black text-xs font-bold rounded hover:bg-zinc-200 transition-colors">
            + Add User
        </a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto space-y-6">
        <% if (success_msg) { %>
            <div class="bg-emerald-950/30 border border-emerald-700 text-emerald-300 px-4 py-3 rounded text-sm">
                <%= success_msg %>
            </div>
        <% } %>

        <% if (error_msg) { %>
            <div class="bg-red-950/30 border border-red-700 text-red-300 px-4 py-3 rounded text-sm">
                <%= error_msg %>
            </div>
        <% } %>

        <div class="bg-[#111111] border border-[#262626] rounded-xl overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-[#161616] text-zinc-400 text-xs uppercase">
                    <tr>
                        <th class="px-4 py-3 text-left">Name</th>
                        <th class="px-4 py-3 text-left">Username</th>
                        <th class="px-4 py-3 text-left">Role</th>
                        <th class="px-4 py-3 text-left">Assigned Properties</th>
                        <th class="px-4 py-3 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#262626]">
                    <% users.forEach(user => { %>
                        <tr>
                            <td class="px-4 py-3 text-white font-semibold"><%= user.full_name || user.username %></td>
                            <td class="px-4 py-3 text-zinc-400 font-mono"><%= user.username %></td>
                            <td class="px-4 py-3">
                                <span class="px-2 py-1 rounded text-[10px] font-bold uppercase <%= user.role === 'Super Admin' ? 'bg-blue-950/40 text-blue-300 border border-blue-700/40' : 'bg-zinc-900 text-zinc-300 border border-zinc-700' %>">
                                    <%= user.role || 'User' %>
                                </span>
                            </td>
                            <td class="px-4 py-3 text-zinc-300"><%= user.assignedCount %></td>
                            <td class="px-4 py-3 text-right">
                                <div class="inline-flex gap-2">
                                    <a href="/users/<%= user.id %>/assign" class="px-3 py-1.5 bg-[#1C1C1E] text-blue-400 border border-[#2E2E30] rounded text-xs font-semibold hover:text-blue-300">
                                        Assign
                                    </a>
                                    <a href="/users/<%= user.id %>/edit" class="px-3 py-1.5 bg-[#1C1C1E] text-zinc-300 border border-[#2E2E30] rounded text-xs font-semibold hover:text-white">
                                        Edit
                                    </a>
                                    <form action="/users/<%= user.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete this user?');">
                                        <button type="submit" class="px-3 py-1.5 bg-red-950/30 text-red-300 border border-red-900/40 rounded text-xs font-semibold hover:bg-red-900/40">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>

                    <% if (!users || users.length === 0) { %>
                        <tr>
                            <td colspan="5" class="px-4 py-8 text-center text-zinc-500">
                                No users found.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>