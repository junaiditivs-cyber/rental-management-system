<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Overview &gt; <span class="text-zinc-200">Registered Tenants</span></div>
        <a href="/tenants/add" class="px-4 py-1.5 bg-white text-black text-xs font-semibold rounded hover:bg-zinc-200 transition-all">
            + Register Tenant
        </a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto space-y-6">
        <div>
            <h1 class="text-white text-xl font-bold tracking-tight">Tenants Directory</h1>
            <p class="text-zinc-500 text-xs mt-1">Directly view and edit communications metadata, active lease details, and previous contract logs.</p>
        </div>

        <div class="bg-[#111111] border border-[#262626] rounded-xl overflow-hidden shadow-lg">
            <table class="w-full text-left border-collapse text-sm">
                <thead>
                    <tr class="border-b border-[#1F1F1F] bg-[#161616] text-[10px] font-bold text-zinc-500 uppercase tracking-wider">
                        <th class="p-4">Tenant Name</th>
                        <th class="p-4">Father Name</th>
                        <th class="p-4">CNIC Verification</th>
                        <th class="p-4">Phone Number</th>
                        <th class="p-4">Outstanding Agreement Status</th>
                        <th class="p-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#1F1F1F] text-zinc-300">
                    <% if (tenants && tenants.length > 0) { %>
                        <% tenants.forEach(t => { %>
                            <tr class="hover:bg-[#161616]/30 transition-colors">
                                <td class="p-4 font-semibold text-white">
                                    <a href="/tenants/<%= t.id %>" class="hover:text-blue-400 font-medium transition-colors">
                                        <%= t.name %>
                                    </a>
                                </td>
                                <td class="p-4 text-zinc-400"><%= t.father_name %></td>
                                <td class="p-4 font-mono text-xs text-zinc-400"><%= t.cnic %></td>
                                <td class="p-4 font-mono text-xs text-zinc-400"><%= t.phone %></td>
                                <td class="p-4">
                                    <% if (t.isLeaseActive) { %>
                                        <span class="px-2 py-0.5 bg-emerald-950/80 text-emerald-400 border border-emerald-800/35 text-[9px] font-bold font-mono tracking-wide rounded">
                                            ACTIVE LEASE
                                        </span>
                                    <% } else { %>
                                        <span class="px-2 py-0.5 bg-zinc-900 border border-zinc-800 text-zinc-500 text-[9px] font-bold font-mono tracking-wide rounded">
                                            NO ACTIVE LEASE
                                        </span>
                                    <% } %>
                                </td>
                                <td class="p-4 text-right space-x-1.5 shrink-0 whitespace-nowrap">
                                    <a href="/tenants/<%= t.id %>" class="text-xs text-zinc-300 hover:text-white bg-[#1C1C1E] border border-zinc-800 px-2 py-1 rounded">
                                        View Details
                                    </a>
                                    <a href="/tenants/<%= t.id %>/edit" class="text-xs text-zinc-400 hover:text-white bg-zinc-900 border border-zinc-800 px-2 py-1 rounded">
                                        Edit
                                    </a>
                                    <form action="/tenants/<%= t.id %>/delete" method="POST" class="inline" 
                                          onsubmit="return confirm('WARNING: Are you sure you want to delete this Tenant? Removing a tenant will affect any linked lease history and payment archives.');">
                                        <button type="submit" class="text-xs text-red-400 hover:text-red-300 bg-red-950/20 border border-red-900/30 px-2 py-1 rounded">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="p-8 text-center text-zinc-500">
                                No tenants currently registered in database. Register tenants to allocate lease agreements.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
