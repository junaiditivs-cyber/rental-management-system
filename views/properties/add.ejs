<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Properties &gt; <span class="text-zinc-200">Register New Property</span></div>
        <a href="/properties" class="text-xs text-zinc-400 hover:text-white transition-colors">&larr; Back to list</a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto max-w-2xl space-y-6">
        <div>
            <h1 class="text-white text-lg font-bold tracking-tight">Add New Property Node</h1>
            <p class="text-zinc-500 text-xs mt-1">Add general housing plazas, malls, flat blocks, or room sectors to construct unit arrays.</p>
        </div>

        <form action="/properties/add" method="POST" class="bg-[#111111] border border-[#262626] p-6 rounded-xl space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="name" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Property Name</label>
                    <input type="text" id="name" name="name" required placeholder="e.g. ABC Plaza"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-600 focus:outline-none focus:border-blue-500/80 transition-all">
                </div>

                <div>
                    <label for="property_type" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Property Type</label>
                    <select id="property_type" name="property_type" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        <option value="Plaza">Plaza</option>
                        <option value="House">House</option>
                        <option value="Shop Line">Shop Line</option>
                        <option value="Flat Building">Flat Building</option>
                        <option value="Basement">Basement</option>
                        <option value="Office Building">Office Building</option>
                        <option value="Room Building">Room Building</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="city_select" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">City</label>
                    <select id="city_select" name="city_id" required onchange="filterAreasByCity(this.value)"
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        <option value="">-- Choose City --</option>
                        <% cities.forEach(c => { %>
                            <option value="<%= c.id %>" <%= typeof p_city_id !== 'undefined' && p_city_id === c.id ? 'selected' : '' %>><%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div>
                    <label for="area_select" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Area / Sector</label>
                    <select id="area_select" name="area_id" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        <option value="">-- Choose Area --</option>
                    </select>
                </div>
            </div>

            <div>
                <label for="address" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Physical Address</label>
                <input type="text" id="address" name="address" required placeholder="e.g. Main Saddar Road, Peshawar Campus"
                       class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-600 focus:outline-none focus:border-blue-500/80 transition-all">
            </div>

            <div>
                <label for="description" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Description / Access Notes (Optional)</label>
                <textarea id="description" name="description" rows="3" placeholder="Add custom notes about key locations, meters, or management..."
                          class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-650 focus:outline-none focus:border-blue-500/80 transition-all"></textarea>
            </div>

            <div>
                <label for="img_url" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Property Preview Image Link (Optional)</label>
                <input type="url" id="img_url" name="img_url" placeholder="https://images.unsplash.com/photo-example..."
                       class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-600 focus:outline-none focus:border-blue-500/80 transition-all">
                <span class="text-[10px] text-zinc-500 mt-1 block">Leaving this blank won't prevent saving. Files are fully optional.</span>
            </div>

            <div class="pt-4 border-t border-[#1F1F1F] flex justify-end gap-3">
                <a href="/properties" class="px-4 py-2 bg-[#1A1A1A] hover:bg-[#2A2A2A] text-zinc-400 hover:text-white border border-[#262626] text-xs font-semibold rounded-md transition-all">
                    Cancel
                </a>
                <button type="submit" class="px-4 py-2 bg-white text-black hover:bg-zinc-200 text-xs font-bold rounded-md transition-all">
                    Create Property
                </button>
            </div>
        </form>
    </div>
</main>

<script>
    // Client-side dynamic area filter mapping object
    const areas = <%- JSON.stringify(areas) %>;
    
    function filterAreasByCity(cityId) {
        const areaSelect = document.getElementById('area_select');
        areaSelect.innerHTML = '<option value="">-- Choose Area --</option>';
        
        if (!cityId) return;
        
        const filteredAreas = areas.filter(a => a.city_id === cityId);
        filteredAreas.forEach(a => {
            const opt = document.createElement('option');
            opt.value = a.id;
            opt.textContent = a.name;
            areaSelect.appendChild(opt);
        });
    }

    // Auto-trigger if city is preset
    document.addEventListener('DOMContentLoaded', () => {
        const cityId = document.getElementById('city_select').value;
        if (cityId) {
            filterAreasByCity(cityId);
        }
    });
</script>

<%- include('../partials/footer') %>
