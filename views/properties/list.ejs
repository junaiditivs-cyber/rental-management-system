<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Overview &gt; <span class="text-zinc-200">Properties</span></div>
        <a href="/properties/add" class="px-4 py-1.5 bg-white text-black text-xs font-semibold rounded-md hover:bg-zinc-200 transition-all">
            + Add Property
        </a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto space-y-6">
        <div class="flex justify-between items-start">
            <div>
                <h1 class="text-white text-xl font-bold tracking-tight">Active Property Portfolio</h1>
                <p class="text-zinc-500 text-xs mt-1">Select any property card to view floors, inspect unit configurations, and manage tenant leases.</p>
            </div>
        </div>

        <!-- Filtering / Search option (client side or basic filter) -->
        <div class="bg-[#111111] border border-[#262626] p-4 rounded-xl flex flex-wrap gap-4 items-center">
            <span class="text-zinc-500 text-xs font-mono">Filters:</span>
            <select onchange="window.location.href=this.value" class="bg-[#161616] border border-[#262626] rounded px-3 py-1 text-xs text-zinc-300">
                <option value="/properties">All Cities</option>
                <% cities.forEach(c => { %>
                    <option value="/properties?city_id=<%= c.id %>" <%= typeof selected_city_id !== 'undefined' && selected_city_id === c.id ? 'selected' : '' %>><%= c.name %></option>
                <% }) %>
            </select>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% if (properties && properties.length > 0) { %>
                <% properties.forEach(prop => { %>
                    <div class="bg-[#161616] border border-[#262626] rounded-xl overflow-hidden hover:border-zinc-500/30 transition-all cursor-pointer group flex flex-col h-full justify-between"
                         onclick="window.location.href='/properties/<%= prop.id %>'">
                        
                        <!-- Top Image Banner -->
                        <div class="h-36 w-full bg-zinc-900 overflow-hidden relative border-b border-[#1F1F1F]">
                            <% if (prop.img_url) { %>
                                <img src="<%= prop.img_url %>" alt="Image of <%= prop.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" referrerpolicy="no-referrer">
                            <% } else { %>
                                <div class="w-full h-full flex flex-col items-center justify-center text-zinc-650">
                                    <span class="text-xs font-mono uppercase tracking-widest"><%= prop.property_type %></span>
                                    <span class="text-[10px] text-zinc-700 mt-1">No custom photo uploaded</span>
                                </div>
                            <% } %>
                            
                            <!-- Floated Status -->
                            <div class="absolute top-3 right-3 shrink-0">
                                <span class="px-2 py-0.5 rounded text-[9px] font-bold font-mono tracking-wide uppercase shadow-lg <%= prop.status === 'Active' ? 'bg-emerald-950/80 border border-emerald-500/30 text-emerald-400' : 'bg-zinc-950/80 border border-zinc-700/30 text-zinc-400' %>">
                                    <%= prop.status %>
                                </span>
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="p-5 flex-1 flex flex-col justify-between">
                            <div>
                                <div class="text-[10px] text-blue-400 font-mono font-bold uppercase tracking-widest mb-1.5 flex items-center justify-between">
                                    <span><%= prop.city_name %> &bull; <%= prop.area_name %></span>
                                </div>
                                <h3 class="text-white text-lg font-semibold group-hover:text-blue-400 transition-colors truncate"><%= prop.name %></h3>
                                <p class="text-zinc-400 text-xs mt-1.5 line-clamp-2"><%= prop.address %></p>
                            </div>

                            <div class="grid grid-cols-3 gap-1 text-center pt-5 mt-4 border-t border-[#1F1F1F]/40">
                                <div class="bg-[#1F1F1F]/30 p-2 rounded">
                                    <div class="text-[9px] text-zinc-500 uppercase font-black">Floors</div>
                                    <div class="text-xs font-semibold text-zinc-200 mt-0.5"><%= prop.floorCount %></div>
                                </div>
                                <div class="bg-[#1F1F1F]/30 p-2 rounded">
                                    <div class="text-[9px] text-zinc-500 uppercase font-black">Units</div>
                                    <div class="text-xs font-semibold text-zinc-200 mt-0.5"><%= prop.unitCount %></div>
                                </div>
                                <div class="bg-emerald-950/10 border border-emerald-950/30 p-2 rounded">
                                    <div class="text-[9px] text-emerald-500/80 uppercase font-black">Occupied</div>
                                    <div class="text-xs font-semibold text-emerald-400 mt-0.5"><%= prop.rentedCount %></div>
                                </div>
                            </div>
                        </div>

                        <!-- Card Footer -->
                        <div class="bg-[#1E1E1E]/40 px-5 py-3.5 border-t border-[#262626]/80 flex justify-between items-center text-xs group-hover:bg-[#222224] transition-colors">
                            <span class="text-zinc-500 font-mono text-[10px] uppercase">Property Node ID</span>
                            <span class="text-zinc-400 font-mono text-[11px]"><%= prop.id.slice(0, 8) %></span>
                        </div>

                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-3 bg-[#111111] p-12 border border-[#262626] rounded-xl text-center text-zinc-500">
                    <p>No properties mapped in database matching filtering.</p>
                    <a href="/properties/add" class="inline-block mt-3 px-4 py-2 bg-white text-black text-xs font-bold rounded">
                        Add First Property
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
