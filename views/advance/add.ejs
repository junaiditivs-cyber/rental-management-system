<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Advances Tracker &gt; <span class="text-zinc-200">Record Advance Security</span></div>
        <a href="javascript:history.back()" class="text-xs text-zinc-400 hover:text-white transition-colors">&larr; Cancel</a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto max-w-2xl space-y-6">
        <div>
            <h1 class="text-white text-lg font-bold tracking-tight">Record Security Advance / Deposit</h1>
            <p class="text-zinc-500 text-xs mt-1">Add a new advance payment received from a tenant. This will increase their tracked advance balance.</p>
        </div>

        <% if (locals.error_msg) { %>
            <div class="p-4 bg-red-950/30 border border-red-500/20 text-red-500 text-xs rounded-xl flex items-center justify-between shadow-md font-sans">
                <div class="flex items-center gap-2">
                    <span>⚠️</span>
                    <span><%= error_msg %></span>
                </div>
                <button onclick="this.parentElement.remove()" class="text-red-500 font-bold">&times;</button>
            </div>
        <% } %>

        <form action="/advance/add" method="POST" class="bg-[#111111] border border-[#262626] p-6 rounded-xl space-y-4 font-sans">
            
            <div>
                <label for="agreement_id" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Link to Active Lease Contract</label>
                <select id="agreement_id" name="agreement_id" required onchange="presetAdvance(this.value)"
                        class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    <option value="">-- Choose Tenant Agreement --</option>
                    <% agreements.forEach(ag => { %>
                        <option value="<%= ag.id %>" data-advance="<%= ag.advance_amount %>">
                            <%= ag.unit_name %> (Tenant: <%= ag.tenant_name %> &bull; Contract security: ₨ <%= ag.advance_amount.toLocaleString() %>)
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="amount" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5 font-bold text-emerald-400">Advance Security Amount (PKR)</label>
                    <input type="number" id="amount" name="amount" required min="1" placeholder="e.g. 50000"
                           class="w-full px-3 py-2 bg-[#161616] border border-blue-500/30 rounded-md text-white text-sm focus:outline-none focus:border-blue-500 font-mono">
                </div>

                <div>
                    <label for="received_date" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Date Received</label>
                    <input type="date" id="received_date" name="received_date" required value="<%= new Date().toISOString().split('T')[0] %>"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all font-mono">
                </div>
            </div>

            <div>
                <label for="payment_method" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Payment Channel</label>
                <select id="payment_method" name="payment_method" required
                        class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                    <option value="Cash">Cash Handover</option>
                    <option value="Bank">Bank Wire Transfer</option>
                    <option value="EasyPaisa">EasyPaisa</option>
                    <option value="JazzCash">JazzCash</option>
                    <option value="Chq">Cheque Clear</option>
                    <option value="Other">Other Gateway</option>
                </select>
            </div>

            <div>
                <label for="notes" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Remarks / Receipt Details (Optional)</label>
                <textarea id="notes" name="notes" rows="3" placeholder="Reference code, bank receipt number, or token commitment terms..."
                          class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm focus:outline-none focus:border-blue-500/80 transition-all"></textarea>
            </div>

            <div class="pt-4 border-t border-[#1F1F1F] flex justify-end gap-3">
                <button type="button" onclick="history.back()" class="px-4 py-2 bg-[#1A1A1A] hover:bg-[#2A2A2A] text-zinc-400 hover:text-white border border-[#262626] text-xs font-semibold rounded-md transition-all">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-white text-black hover:bg-zinc-200 text-xs font-bold rounded-md transition-all">
                    Record Deposit
                </button>
            </div>
        </form>
    </div>
</main>

<script>
    function presetAdvance(agreeId) {
        if (!agreeId) return;
        const select = document.getElementById('agreement_id');
        const opt = select.options[select.selectedIndex];
        const advVal = opt.getAttribute('data-advance') || '0';
        document.getElementById('amount').value = advVal;
    }
</script>

<%- include('../partials/footer') %>
