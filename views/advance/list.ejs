<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Overview &gt; <span class="text-zinc-200">Security Advance Deposits</span></div>
        <a href="/advance/add" class="px-4 py-1.5 bg-white text-black text-xs font-semibold rounded hover:bg-zinc-200 transition-all">
            + Record Advance Payment
        </a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto space-y-6">
        <div>
            <h1 class="text-white text-xl font-bold tracking-tight">Advances Tracker</h1>
            <p class="text-zinc-500 text-xs mt-1">Manage security deposits and token advances collected from tenants. Safe deletion or refund edits are fully supported here.</p>
        </div>

        <% if (locals.success_msg) { %>
            <div class="p-4 bg-emerald-950/30 border border-emerald-500/20 text-emerald-400 text-xs rounded-xl flex items-center justify-between shadow-md font-sans">
                <div class="flex items-center gap-2">
                    <span class="text-sm">✅</span>
                    <span><%= success_msg %></span>
                </div>
                <button onclick="this.parentElement.remove()" class="text-emerald-500 hover:text-emerald-300 font-bold text-sm">&times;</button>
            </div>
        <% } %>

        <% if (locals.error_msg) { %>
            <div class="p-4 bg-red-950/30 border border-red-500/20 text-red-400 text-xs rounded-xl flex items-center justify-between shadow-md font-sans">
                <div class="flex items-center gap-2">
                    <span class="text-sm">⚠️</span>
                    <span><%= error_msg %></span>
                </div>
                <button onclick="this.parentElement.remove()" class="text-red-500 hover:text-red-300 font-bold text-sm">&times;</button>
            </div>
        <% } %>

        <div class="bg-[#111111] border border-[#262626] rounded-xl overflow-hidden shadow-lg">
            <table class="w-full text-left border-collapse text-xs font-mono">
                <thead>
                    <tr class="border-b border-[#1F1F1F] bg-[#161616] text-[10px] font-bold text-zinc-500 uppercase tracking-wider font-sans">
                        <th class="p-4">Received On</th>
                        <th class="p-4">Tenant / Client</th>
                        <th class="p-4">Allocated Unit</th>
                        <th class="p-4">Advance Amount (PKR)</th>
                        <th class="p-4">Payment Method</th>
                        <th class="p-4">Admin Remarks / Notes</th>
                        <th class="p-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#1F1F1F] text-zinc-300">
                    <% if (advances && advances.length > 0) { %>
                        <% advances.forEach(adv => { %>
                            <tr class="hover:bg-[#161616]/20 transition-colors">
                                <td class="p-4 font-sans text-zinc-400"><%= adv.received_date %></td>
                                <td class="p-4 font-sans font-semibold text-white">
                                    <a href="/tenants/<%= adv.tenant_id %>" class="hover:text-blue-400 underline decoration-dotted"><%= adv.tenant_name %></a>
                                </td>
                                <td class="p-4 font-sans text-zinc-300">
                                    <a href="/units/<%= adv.unit_id %>" class="hover:underline"><%= adv.unit_name %></a>
                                </td>
                                <td class="p-4 text-emerald-400 font-bold text-sm">₨ <%= adv.amount.toLocaleString() %></td>
                                <td class="p-4 font-sans text-zinc-400 capitalize"><%= adv.payment_method %></td>
                                <td class="p-4 font-sans text-zinc-400 truncate max-w-xs" title="<%= adv.notes %>"><%= adv.notes || '-' %></td>
                                <td class="p-4 text-right font-sans space-x-2 shrink-0">
                                    <a href="/advance/<%= adv.id %>/edit" class="text-xs text-zinc-300 hover:text-white bg-[#1C1C1E] border border-zinc-800 px-2 py-1 rounded">
                                        Edit
                                    </a>
                                    <form action="/advance/<%= adv.id %>/delete" method="POST" class="inline" 
                                          onsubmit="return confirm('WARNING: Are you sure you want to delete this Advance Deposit record? This operation affects historical accounts and cannot be reversed.');">
                                        <button type="submit" class="text-xs text-red-400 hover:text-red-300 bg-red-950/20 border border-red-900/30 px-2 py-1 rounded">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="p-12 text-center text-zinc-500 font-sans">
                                No security advance payments recorded. Use the Register button to log one.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
