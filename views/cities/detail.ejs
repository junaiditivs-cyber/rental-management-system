<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Cities &gt; <span class="text-zinc-200"><%= city.name %> Details</span></div>
        <div class="flex gap-2 items-center">
            <a href="/cities/<%= city.id %>/edit" class="px-3 py-1.5 bg-[#1F1F1F] text-zinc-300 text-xs font-semibold rounded-md border border-[#262626] hover:text-white transition-colors">
                Edit City Details
            </a>
            <% if (city.propertiesCount === 0 && city.areasCount === 0) { %>
                <form action="/cities/<%= city.id %>/delete" method="POST" class="inline" onsubmit="return confirm('WARNING: Are you sure you want to delete this empty city? This cannot be undone.');">
                    <button type="submit" class="px-3 py-1.5 bg-red-950/20 border border-red-900/30 text-red-000 text-xs font-bold rounded-md hover:bg-red-900/40 text-red-400 transition-colors">
                        Delete City
                    </button>
                </form>
            <% } %>
            <a href="/areas/add?city_id=<%= city.id %>" class="px-3 py-1.5 bg-[#1F1F1F] text-zinc-300 text-xs font-semibold rounded-md border border-[#262626] hover:text-white transition-colors">
                + Add Area
            </a>
            <a href="/properties/add?city_id=<%= city.id %>" class="px-3 py-1.5 bg-white text-black text-xs font-semibold rounded-md hover:bg-zinc-200 transition-colors">
                + Add Property
            </a>
        </div>
    </header>

    <div class="p-8 flex-1 overflow-y-auto space-y-8">
        <!-- Title bar -->
        <div class="flex justify-between items-start">
            <div>
                <span class="text-xs text-blue-400 font-bold uppercase tracking-widest"><%= city.province %> Region</span>
                <h1 class="text-white text-3xl font-bold tracking-tight mt-1"><%= city.name %></h1>
                <p class="text-zinc-500 text-xs">Total portfolio and financial flow metrics representing units within this municipal center.</p>
            </div>
            <a href="/cities" class="text-xs text-zinc-400 hover:text-white">&larr; Cities Overview</a>
        </div>

        <!-- Mini stats block inside city -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="bg-[#111111] border border-[#262626] p-4 rounded-lg">
                <div class="text-[10px] uppercase font-bold text-zinc-500">Total Registered Areas</div>
                <div class="text-xl font-bold text-white mt-1"><%= areas.length %></div>
            </div>
            <div class="bg-[#111111] border border-[#262626] p-4 rounded-lg">
                <div class="text-[10px] uppercase font-bold text-zinc-500">Total Properties</div>
                <div class="text-xl font-bold text-white mt-1"><%= properties.length %></div>
            </div>
            <div class="bg-[#111111] border border-[#262626] p-4 rounded-lg">
                <div class="text-[10px] uppercase font-bold text-emerald-500/80">Rented vs Vacant</div>
                <div class="text-xl font-bold text-emerald-400 mt-1 flex items-baseline gap-2">
                    <%= stats.rentedCount %> Rented
                    <span class="text-xs text-red-400 font-normal">/ <%= stats.vacantCount %> Vacant</span>
                </div>
            </div>
            <div class="bg-[#111111] border border-[#262626] p-4 rounded-lg">
                <div class="text-[10px] uppercase font-bold text-amber-500/80">Pending Rents Outstanding</div>
                <div class="text-xl font-bold text-amber-400 mt-1">₨ <%= stats.pendingRent.toLocaleString() %></div>
            </div>
        </div>

        <!-- Grid for Areas & Properties -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Areas list (Left Column) -->
            <div class="lg:col-span-1 space-y-4">
                <div class="flex justify-between items-center">
                    <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest">Included Sectors / Areas</h3>
                    <a href="/areas/add?city_id=<%= city.id %>" class="text-xs text-blue-400 hover:text-blue-300 font-semibold">+ Add Area</a>
                </div>

                <div class="bg-[#111111] border border-[#262626] rounded-xl overflow-hidden divide-y divide-[#1F1F1F]">
                    <% if (areas && areas.length > 0) { %>
                        <% areas.forEach(area => { %>
                            <div class="p-4 flex justify-between items-center hover:bg-[#161616]/30 transition-colors">
                                <div>
                                    <h4 class="text-sm font-semibold text-white"><%= area.name %></h4>
                                    <p class="text-[10px] text-zinc-500">Area Identifier: <%= area.id %></p>
                                </div>
                                <div class="flex items-center gap-2">
                                    <a href="/areas/<%= area.id %>/edit" class="text-[11px] text-zinc-400 hover:text-white bg-[#1A1A1A] border border-[#262626] px-1.5 py-0.5 rounded">
                                        Edit
                                    </a>
                                    <form action="/areas/<%= area.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete area and all links?');">
                                        <button type="submit" class="text-[11px] text-red-400 hover:text-red-300 bg-red-950/20 border border-red-900/30 px-1.5 py-0.5 rounded font-mono">
                                            &times;
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="p-6 text-center text-zinc-500 text-xs">No areas added yet inside <%= city.name %>.</div>
                    <% } %>
                </div>
            </div>

            <!-- Properties list (Right Column - larger width) -->
            <div class="lg:col-span-2 space-y-4">
                <div class="flex justify-between items-center">
                    <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest">Linked Properties</h3>
                    <a href="/properties/add?city_id=<%= city.id %>" class="text-xs text-blue-400 hover:text-blue-300 font-semibold">+ Add Property</a>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% if (properties && properties.length > 0) { %>
                        <% properties.forEach(prop => { %>
                            <div class="bg-[#161616] border border-[#262626] rounded-xl p-5 hover:border-zinc-500/30 transition-all cursor-pointer flex flex-col justify-between"
                                 onclick="window.location.href='/properties/<%= prop.id %>'">
                                <div>
                                    <div class="flex justify-between items-start mb-2">
                                        <span class="px-2 py-0.5 bg-[#262626] border border-zinc-800 text-[10px] font-mono rounded text-zinc-400"><%= prop.property_type %></span>
                                        <span class="w-2 h-2 rounded-full <%= prop.status === 'Active' ? 'bg-emerald-500' : 'bg-zinc-500' %>" title="<%= prop.status %>"></span>
                                    </div>
                                    <h4 class="text-base font-bold text-white mb-1 hover:text-blue-400 transition-colors"><%= prop.name %></h4>
                                    <p class="text-xs text-zinc-400 truncate"><%= prop.address %></p>
                                </div>
                                <div class="border-t border-[#1F1F1F] mt-4 pt-3 flex justify-between items-center text-[11px]">
                                    <span class="text-zinc-500">Sector/Area: <strong class="text-zinc-300"><%= prop.area_name %></strong></span>
                                    <span class="text-blue-400 font-semibold">View Detail &rarr;</span>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-span-2 bg-[#111111] border border-[#262626] p-8 rounded-xl text-center text-zinc-500 text-xs">
                            No property registered under this city yet. Register properties to define floors and rental units.
                        </div>
                    <% } %>
                </div>
            </div>

        </div>
    </div>
</main>

<%- include('../partials/footer') %>
