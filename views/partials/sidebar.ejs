                    PK
                </div>

                <div>
                    <div class="text-white text-base font-black tracking-tight leading-none">
                        PK RENTALS
                    </div>
                    <div class="text-[10px] text-blue-300/70 font-black uppercase tracking-[0.18em] mt-1.5">
                        Admin Console
                    </div>
                </div>
            </a>

            <button id="theme-toggle" class="w-10 h-10 rounded-2xl bg-white/[0.045] hover:bg-white/[0.08] border border-white/10 text-slate-400 hover:text-white transition-all focus:outline-none flex items-center justify-center" title="Toggle Theme">
