<% const activeClass = "flex items-center gap-3 px-3 py-2.5 bg-[#161616] text-white rounded-md text-sm font-medium border border-[#262626] transition-all"; %>
<% const inactiveClass = "flex items-center gap-3 px-3 py-2.5 text-zinc-400 hover:text-white hover:bg-[#161616]/60 rounded-md text-sm font-medium border border-transparent hover:border-[#1F1F1F] transition-all"; %>

<!-- Mobile Top Navigation Bar (Visible only on Mobile & Tables) -->
<div class="md:hidden h-14 border-b border-[#1F1F1F] bg-[#0A0A0A] flex items-center justify-between px-6 shrink-0 z-40 transition-colors" id="mobile-top-bar">
    <button id="mobile-hamburger" class="text-white focus:outline-none p-1.5 hover:bg-[#161616] rounded-md transition-colors" aria-label="Toggle Sidebar Menu">
        <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
    </button>
    <div class="text-white text-sm font-bold tracking-tight select-none flex items-center gap-1.5">
        <div class="w-2.5 h-2.5 rounded-full bg-blue-500"></div>
        PK RENTALS
    </div>
    <div class="w-8"></div><!-- Placeholder grid spacer for centering alignment -->
</div>

<!-- Mobile backdrop overlay for sliding drawer -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/60 hidden z-40 transition-opacity duration-300 backdrop-blur-xs md:hidden"></div>

<!-- Sidebar Component Navigation Panel -->
<aside id="sidebar-container" class="w-64 border-r border-[#1F1F1F] bg-[#0A0A0A] flex flex-col h-full shrink-0 max-md:fixed max-md:inset-y-0 max-md:left-0 max-md:z-50 max-md:transform max-md:-translate-x-full transition-all duration-300 ease-in-out">
    <!-- Brand / Title -->
    <div class="p-6 border-b border-[#1F1F1F] flex items-center justify-between shrink-0">
        <a href="/" class="text-white font-bold tracking-tight flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-blue-500 animate-pulse"></div>
            PK RENTALS
        </a>
        <div class="flex items-center gap-1.5">
            <!-- Smooth Theme Toggle Button -->
            <button id="theme-toggle" class="p-1.5 rounded-md hover:bg-[#161616] border border-transparent hover:border-[#262626] text-zinc-400 hover:text-white transition-all focus:outline-none" title="Toggle Theme (Light / Dark Modes)">
                <!-- Sun Icon -->
                <svg id="theme-icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"></circle>
                    <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
                </svg>
                <!-- Moon Icon -->
                <svg id="theme-icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Navigation List -->
    <nav class="flex-1 p-4 space-y-1.5 overflow-y-auto">
        <div class="text-[10px] font-bold text-zinc-500 tracking-wider uppercase px-3 mb-2">Main Controls</div>
        
        <a href="/dashboard" class="<%= typeof activeTab !== 'undefined' && activeTab === 'dashboard' ? activeClass : inactiveClass %>" id="nav-dashboard">
            <span>Dashboard</span>
        </a>
        <a href="/smart-entry" class="<%= typeof activeTab !== 'undefined' && activeTab === 'smart-entry' ? activeClass : inactiveClass %>" id="nav-smart-entry">
            <span class="flex items-center gap-1.5 text-blue-400 font-semibold">⚡ + Smart Entry</span>
        </a>
        <a href="/cities" class="<%= typeof activeTab !== 'undefined' && activeTab === 'cities' ? activeClass : inactiveClass %>" id="nav-cities">
            <span>Cities</span>
        </a>
        <a href="/areas" class="<%= typeof activeTab !== 'undefined' && activeTab === 'areas' ? activeClass : inactiveClass %>" id="nav-areas">
            <span>Areas</span>
        </a>
        <a href="/properties" class="<%= typeof activeTab !== 'undefined' && activeTab === 'properties' ? activeClass : inactiveClass %>" id="nav-properties">
            <span>Properties</span>
        </a>
        <a href="/units" class="<%= typeof activeTab !== 'undefined' && activeTab === 'units' ? activeClass : inactiveClass %>" id="nav-units">
            <span>Units &amp; Floors</span>
        </a>

        <div class="pt-4 text-[10px] font-bold text-zinc-500 tracking-wider uppercase px-3 mb-2">Management</div>
        
        <a href="/tenants" class="<%= typeof activeTab !== 'undefined' && activeTab === 'tenants' ? activeClass : inactiveClass %>" id="nav-tenants">
            <span>Tenants Profiles</span>
        </a>
        <a href="/agreements" class="<%= typeof activeTab !== 'undefined' && activeTab === 'agreements' ? activeClass : inactiveClass %>" id="nav-agreements">
            <span>Rent Agreements</span>
        </a>
        <a href="/rent" class="<%= typeof activeTab !== 'undefined' && activeTab === 'rent' ? activeClass : inactiveClass %>" id="nav-rent">
            <span>Rent Ledger / Collect</span>
        </a>
        <a href="/advance" class="<%= typeof activeTab !== 'undefined' && activeTab === 'advance' ? activeClass : inactiveClass %>" id="nav-advance">
            <span>Advances Tracker</span>
        </a>

        <div class="pt-4 text-[10px] font-bold text-zinc-500 tracking-wider uppercase px-3 mb-2">Insights</div>
        
        <a href="/reports" class="<%= typeof activeTab !== 'undefined' && activeTab === 'reports' ? activeClass : inactiveClass %>" id="nav-reports">
            <span>Analytical Reports</span>
        </a>
        <a href="/logs" class="<%= typeof activeTab !== 'undefined' && activeTab === 'logs' ? activeClass : inactiveClass %>" id="nav-logs">
            <span>Activity logs</span>
        </a>
    </nav>

    <!-- Sidebar footer profile details -->
    <div class="p-4 border-t border-[#1F1F1F] bg-[#0E0E0E] flex flex-col gap-3 shrink-0">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-blue-600 to-indigo-800 border border-zinc-700 flex items-center justify-center text-xs text-white font-bold select-none shrink-0">
                PK
            </div>
            <div class="text-xs font-medium overflow-hidden">
                <div class="text-white truncate font-medium"><%= (typeof session !== 'undefined' && session.adminUser) ? session.adminUser.full_name : 'PK Admin' %></div>
                <div class="text-zinc-500 font-mono text-[10px]">Active Session</div>
            </div>
        </div>
        <div class="flex gap-2">
            <a href="/settings" class="flex-1 text-center py-1.5 bg-[#1C1C1E] hover:bg-[#2C2C2E] text-zinc-400 hover:text-white rounded text-[11px] font-medium border border-[#2E2E30] transition-colors">
                Settings
            </a>
            <a href="/logout" class="px-2.5 py-1.5 bg-red-950/20 hover:bg-red-900/30 text-red-400 hover:text-red-300 rounded text-[11px] font-medium border border-red-900/20 transition-colors text-center" title="Log Out App">
                Logout
            </a>
        </div>
    </div>
</aside>

<!-- Dynamic Layout and Theme Initialization and Toggling Handlers -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // --- MULTIPLE SUBMIT PLOCKS & LOADING SPIN STATE ---
        const forms = document.querySelectorAll('form');
        forms.forEach(form => {
            form.addEventListener('submit', function(e) {
                // If submit handler triggers a confirmation or returns false, cancel
                const submitBtns = form.querySelectorAll('button[type="submit"]');
                submitBtns.forEach(btn => {
                    // Slight delay to allow HTML5 validation triggers to execute first
                    setTimeout(() => {
                        if (form.checkValidity()) {
                            btn.disabled = true;
                            const originalHTML = btn.innerHTML;
                            // Add spinner icon
                            btn.innerHTML = `<span class="inline-flex items-center gap-1.5"><svg class="animate-spin h-3 w-3 text-current" viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle class="opacity-25" cx="12" cy="12" r="10" stroke-width="4"></circle><path class="opacity-75" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Saving...</span>`;
                        }
                    }, 10);
                });
            });
        });

        // --- MOBILE SIDEBAR HANDLERS ---
        const hamburgerBtn = document.getElementById('mobile-hamburger');
        const sidebarEl = document.getElementById('sidebar-container');
        const overlayEl = document.getElementById('sidebar-overlay');

        if (hamburgerBtn && sidebarEl && overlayEl) {
            function showMobileSidebar() {
                sidebarEl.classList.remove('max-md:-translate-x-full');
                overlayEl.classList.remove('hidden');
                setTimeout(() => {
                    overlayEl.classList.add('opacity-100');
                }, 10);
            }

            function hideMobileSidebar() {
                sidebarEl.classList.add('max-md:-translate-x-full');
                overlayEl.classList.remove('opacity-100');
                setTimeout(() => {
                    if (sidebarEl.classList.contains('max-md:-translate-x-full')) {
                        overlayEl.classList.add('hidden');
                    }
                }, 300);
            }

            hamburgerBtn.addEventListener('click', showMobileSidebar);
            overlayEl.addEventListener('click', hideMobileSidebar);

            // Hide sidebar on clicking link in phone views
            const responsiveLinks = sidebarEl.querySelectorAll('nav a');
            responsiveLinks.forEach(link => {
                link.addEventListener('click', function() {
                    if (window.innerWidth < 768) {
                        hideMobileSidebar();
                    }
                });
            });
        }

        // --- LIGHT & DARK THEME INTERVENTIONS ---
        const btnToggle = document.getElementById('theme-toggle');
        const iconSun = document.getElementById('theme-icon-sun');
        const iconMoon = document.getElementById('theme-icon-moon');

        function syncThemeIcons() {
            const isLightActive = document.documentElement.classList.contains('light');
            if (isLightActive) {
                if (iconSun) iconSun.classList.remove('hidden');
                if (iconMoon) iconMoon.classList.add('hidden');
            } else {
                if (iconSun) iconSun.classList.add('hidden');
                if (iconMoon) iconMoon.classList.remove('hidden');
            }
        }

        if (btnToggle) {
            // Check initial load matching states
            syncThemeIcons();

            btnToggle.addEventListener('click', function() {
                const targetEl = document.documentElement;
                if (targetEl.classList.contains('light')) {
                    targetEl.classList.remove('light');
                    localStorage.setItem('theme', 'dark');
                } else {
                    targetEl.classList.add('light');
                    localStorage.setItem('theme', 'light');
                }
                syncThemeIcons();
            });
        }
    });
</script>
