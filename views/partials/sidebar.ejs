                <span class="w-9 h-9 rounded-2xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-300 text-xs shrink-0">⚡</span>
                <span class="text-sm font-bold text-blue-300">Smart Entry</span>
            </a>
        <% } %>

        <% if (typeof can === 'function' && can('view_users')) { %>
            <a href="/users" class="<%= typeof activeTab !== 'undefined' && activeTab === 'users' ? activeClass : inactiveClass %>" id="nav-users">
                <span class="w-9 h-9 rounded-2xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-300 text-xs shrink-0">👥</span>
                <span class="text-sm font-bold">Users &amp; Access</span>
            </a>
        <% } %>

        <% if (
            (typeof can === 'function' && can('view_cities')) ||
            (typeof can === 'function' && can('view_areas')) ||
            (typeof can === 'function' && can('view_properties')) ||
            (typeof can === 'function' && can('view_units'))
        ) { %>
            <div class="px-3 pt-6 pb-2 text-[10px] font-black text-slate-500 tracking-[0.20em] uppercase">
                Property Setup
            </div>
        <% } %>

        <% if (typeof can === 'function' && can('view_cities')) { %>
            <a href="/cities" class="<%= typeof activeTab !== 'undefined' && activeTab === 'cities' ? activeClass : inactiveClass %>" id="nav-cities">
                <span class="w-9 h-9 rounded-2xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-300 text-xs shrink-0">🏙</span>
                <span class="text-sm font-bold">Cities</span>
            </a>
        <% } %>

        <% if (typeof can === 'function' && can('view_areas')) { %>
            <a href="/areas" class="<%= typeof activeTab !== 'undefined' && activeTab === 'areas' ? activeClass : inactiveClass %>" id="nav-areas">
                <span class="w-9 h-9 rounded-2xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center text-sky-300 text-xs shrink-0">📍</span>
                <span class="text-sm font-bold">Areas</span>
            </a>
        <% } %>

        <% if (typeof can === 'function' && can('view_properties')) { %>
            <a href="/properties" class="<%= typeof activeTab !== 'undefined' && activeTab === 'properties' ? activeClass : inactiveClass %>" id="nav-properties">
                <span class="w-9 h-9 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-300 text-xs shrink-0">▦</span>
                <span class="text-sm font-bold">Properties</span>
            </a>
        <% } %>

        <% if (typeof can === 'function' && can('view_units')) { %>
            <a href="/units" class="<%= typeof activeTab !== 'undefined' && activeTab === 'units' ? activeClass : inactiveClass %>" id="nav-units">
                <span class="w-9 h-9 rounded-2xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center text-violet-300 text-xs shrink-0">▣</span>
                <span class="text-sm font-bold">Units &amp; Floors</span>
            </a>
        <% } %>

        <% if (
            (typeof can === 'function' && can('view_tenants')) ||
            (typeof can === 'function' && can('view_agreements')) ||
            (typeof can === 'function' && can('view_rent')) ||
            (typeof can === 'function' && can('view_advance'))
        ) { %>
            <div class="px-3 pt-6 pb-2 text-[10px] font-black text-slate-500 tracking-[0.20em] uppercase">
                Management
            </div>
        <% } %>

        <% if (typeof can === 'function' && can('view_tenants')) { %>
            <a href="/tenants" class="<%= typeof activeTab !== 'undefined' && activeTab === 'tenants' ? activeClass : inactiveClass %>" id="nav-tenants">
                <span class="w-9 h-9 rounded-2xl bg-teal-500/10 border border-teal-500/20 flex items-center justify-center text-teal-300 text-xs shrink-0">👤</span>
