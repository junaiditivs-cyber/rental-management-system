<% const activeClass = "group relative flex items-center gap-3 px-3 py-3 rounded-2xl bg-blue-600/15 text-white border border-blue-500/30 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] transition-all"; %>
<% const inactiveClass = "group relative flex items-center gap-3 px-3 py-3 rounded-2xl text-slate-400 hover:text-white hover:bg-white/[0.055] border border-transparent hover:border-white/10 transition-all"; %>

<!-- Mobile Top Navigation Bar -->
<div class="md:hidden h-16 border-b border-slate-800 bg-[#070A10] flex items-center justify-between px-5 shrink-0 z-40">
    <button id="mobile-hamburger" class="text-white focus:outline-none p-2 hover:bg-white/5 rounded-xl transition-colors" aria-label="Toggle Sidebar Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
    </button>

    <div class="text-white text-sm font-black tracking-tight select-none flex items-center gap-2">
        <div class="w-8 h-8 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center text-blue-300 text-xs font-black">
            PK
        </div>
        PK RENTALS
    </div>

    <div class="w-9"></div>
</div>

<!-- Mobile backdrop overlay -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/70 hidden z-40 transition-opacity duration-300 backdrop-blur-sm md:hidden"></div>

<!-- Premium Sidebar -->
<aside id="sidebar-container" class="w-72 border-r border-slate-800 bg-[#070A10] flex flex-col h-full shrink-0 max-md:fixed max-md:inset-y-0 max-md:left-0 max-md:z-50 max-md:transform max-md:-translate-x-full transition-all duration-300 ease-in-out">

    <!-- Brand Header -->
