                <span class="text-sm font-bold">Rent Agreements</span>
            </a>
        <% } %>

        <% if (typeof can === 'function' && can('view_rent')) { %>
            <a href="/rent" class="<%= typeof activeTab !== 'undefined' && activeTab === 'rent' ? activeClass : inactiveClass %>" id="nav-rent">
                <span class="w-9 h-9 rounded-2xl bg-green-500/10 border border-green-500/20 flex items-center justify-center text-green-300 text-xs shrink-0">₨</span>
                <span class="text-sm font-bold">Rent Ledger / Collect</span>
            </a>
        <% } %>

        <% if (typeof can === 'function' && can('view_advance')) { %>
            <a href="/advance" class="<%= typeof activeTab !== 'undefined' && activeTab === 'advance' ? activeClass : inactiveClass %>" id="nav-advance">
                <span class="w-9 h-9 rounded-2xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-300 text-xs shrink-0">A</span>
                <span class="text-sm font-bold">Advances Tracker</span>
            </a>
        <% } %>

        <% if (
            (typeof can === 'function' && can('view_reports')) ||
            (typeof can === 'function' && can('view_logs'))
        ) { %>
            <div class="px-3 pt-6 pb-2 text-[10px] font-black text-slate-500 tracking-[0.20em] uppercase">
                Insights
            </div>
        <% } %>

        <% if (typeof can === 'function' && can('view_reports')) { %>
            <a href="/reports" class="<%= typeof activeTab !== 'undefined' && activeTab === 'reports' ? activeClass : inactiveClass %>" id="nav-reports">
                <span class="w-9 h-9 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-300 text-xs shrink-0">↗</span>
                <span class="text-sm font-bold">Analytical Reports</span>
            </a>
        <% } %>

        <% if (typeof can === 'function' && can('view_logs')) { %>
            <a href="/logs" class="<%= typeof activeTab !== 'undefined' && activeTab === 'logs' ? activeClass : inactiveClass %>" id="nav-logs">
                <span class="w-9 h-9 rounded-2xl bg-slate-500/10 border border-slate-500/20 flex items-center justify-center text-slate-300 text-xs shrink-0">☷</span>
                <span class="text-sm font-bold">Activity Logs</span>
            </a>
        <% } %>
    </nav>

    <!-- Sidebar Footer -->
    <div class="p-4 border-t border-slate-800 bg-[#090C12] shrink-0">
        <div class="rounded-3xl bg-white/[0.045] border border-white/10 p-4 mb-3">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-700 border border-blue-400/30 flex items-center justify-center text-xs text-white font-black select-none shrink-0 shadow-lg shadow-blue-950/30">
                    PK
                </div>

                <div class="text-xs font-medium overflow-hidden">
                    <div class="text-white truncate font-black">
                        <%= (typeof admin !== 'undefined' && admin) ? admin.full_name : 'PK Admin' %>
                    </div>
                    <div class="text-slate-500 font-mono text-[10px] mt-0.5">
                        <%= (typeof admin !== 'undefined' && admin) ? admin.role : 'Active Session' %>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex gap-2">
            <a href="/change-password" class="flex-1 text-center py-2 bg-white/[0.04] hover:bg-white/[0.08] text-slate-400 hover:text-white rounded-2xl text-[11px] font-black border border-white/10 transition-colors">
                Password
            </a>

            <a href="/logout" class="px-3 py-2 bg-red-500/10 hover:bg-red-500/15 text-red-400 hover:text-red-300 rounded-2xl text-[11px] font-black border border-red-500/20 transition-colors text-center" title="Log Out App">
                Logout
            </a>
        </div>
    </div>
</aside>

<!-- Dynamic Layout and Theme Initialization and Toggling Handlers -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // --- SAFE FORM SUBMIT LOADING STATE ---
        const forms = document.querySelectorAll('form');

        forms.forEach(form => {
            form.addEventListener('submit', function(e) {
                const formActionVal = form.getAttribute('action') || '';

                if (formActionVal.includes('/delete')) {
                    return;
                }

                if (form.dataset.submitting === 'true') {
                    e.preventDefault();
                    return;
                }

                if (!form.checkValidity()) {
                    return;
                }

                form.dataset.submitting = 'true';

                const submitBtns = form.querySelectorAll('button[type="submit"]');
                submitBtns.forEach(btn => {
                    btn.dataset.originalHtml = btn.innerHTML;
                    btn.disabled = true;
                    btn.innerHTML = `
                        <span class="inline-flex items-center gap-1.5">
                            <svg class="animate-spin h-3 w-3 text-current" viewBox="0 0 24 24" fill="none">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                            </svg>
                            Saving...
                        </span>
                    `;
                });
            });
        });

        // --- MOBILE SIDEBAR HANDLERS ---
        const hamburgerBtn = document.getElementById('mobile-hamburger');
        const sidebarEl = document.getElementById('sidebar-container');
        const overlayEl = document.getElementById('sidebar-overlay');

        if (hamburgerBtn && sidebarEl && overlayEl) {
            function showMobileSidebar() {
                sidebarEl.classList.remove('max-md:-translate-x-full');
                overlayEl.classList.remove('hidden');

                setTimeout(() => {
                    overlayEl.classList.add('opacity-100');
                }, 10);
            }

            function hideMobileSidebar() {
                sidebarEl.classList.add('max-md:-translate-x-full');
                overlayEl.classList.remove('opacity-100');

                setTimeout(() => {
                    if (sidebarEl.classList.contains('max-md:-translate-x-full')) {
                        overlayEl.classList.add('hidden');
                    }
                }, 300);
            }

            hamburgerBtn.addEventListener('click', showMobileSidebar);
            overlayEl.addEventListener('click', hideMobileSidebar);

            const responsiveLinks = sidebarEl.querySelectorAll('nav a');
            responsiveLinks.forEach(link => {
                link.addEventListener('click', function() {
                    if (window.innerWidth < 768) {
                        hideMobileSidebar();
                    }
                });
            });
        }

        // --- LIGHT & DARK THEME HANDLERS ---
        const btnToggle = document.getElementById('theme-toggle');
        const iconSun = document.getElementById('theme-icon-sun');
        const iconMoon = document.getElementById('theme-icon-moon');

        function syncThemeIcons() {
            const isLightActive = document.documentElement.classList.contains('light');

            if (isLightActive) {
                if (iconSun) iconSun.classList.remove('hidden');
                if (iconMoon) iconMoon.classList.add('hidden');
            } else {
                if (iconSun) iconSun.classList.add('hidden');
                if (iconMoon) iconMoon.classList.remove('hidden');
            }
        }

        if (btnToggle) {
            syncThemeIcons();

            btnToggle.addEventListener('click', function() {
                const targetEl = document.documentElement;

                if (targetEl.classList.contains('light')) {
                    targetEl.classList.remove('light');
                    localStorage.setItem('theme', 'dark');
                } else {
                    targetEl.classList.add('light');
                    localStorage.setItem('theme', 'light');
                }

                syncThemeIcons();
            });
        }
    });
</script>