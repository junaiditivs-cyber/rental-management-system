    </div><!-- End #app-container -->

    <!-- Global Delete Confirmation Modal -->
    <div
        id="delete-confirm-modal"
        class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/80 opacity-0 transition-opacity duration-200 backdrop-blur-sm"
        role="dialog"
        aria-modal="true"
        aria-labelledby="delete-confirm-title"
    >
        <div
            id="delete-confirm-card"
            class="theme-modal-card w-full max-w-md rounded-xl border border-zinc-800 bg-zinc-950 p-6 shadow-2xl scale-95 transition-transform duration-200"
        >
            <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-red-500/30 bg-red-950/40 text-red-400">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                        </path>
                    </svg>
                </div>

                <div class="min-w-0 flex-1">
                    <h3 id="delete-confirm-title" class="text-base font-bold text-zinc-100">
                        Confirm deletion
                    </h3>

                    <p id="delete-confirm-message" class="mt-1.5 text-xs leading-relaxed text-zinc-400">
                        Are you sure you want to delete this record?
                    </p>
                </div>
            </div>

            <div
                id="delete-confirm-error"
                class="mt-4 hidden rounded-lg border border-red-800/50 bg-red-950/30 p-3 text-[11px] leading-relaxed text-red-300"
                aria-live="polite"
            ></div>

            <div class="mt-5 flex justify-end gap-2.5">
                <button
                    id="delete-confirm-cancel"
                    type="button"
                    class="theme-modal-cancel rounded-lg border border-zinc-800 bg-[#1A1A1C] px-3.5 py-1.5 text-xs font-semibold text-zinc-400 transition-colors hover:bg-[#252528] hover:text-white disabled:cursor-not-allowed disabled:opacity-50"
                >
                    Cancel
                </button>

                <button
                    id="delete-confirm-submit"
                    type="button"
                    class="inline-flex min-w-[118px] items-center justify-center gap-1.5 rounded-lg bg-red-600 px-3.5 py-1.5 text-xs font-semibold text-white transition-colors hover:bg-red-500 disabled:cursor-not-allowed disabled:opacity-60"
                >
                    Confirm Delete
                </button>
            </div>
        </div>
    </div>

    <% if (typeof success_msg !== 'undefined' && success_msg) { %>
        <div
            id="toast-success"
            class="fixed bottom-6 right-6 z-[110] flex max-w-sm items-center gap-2 rounded-lg border border-emerald-500/30 bg-emerald-950/90 px-4 py-3 text-xs text-emerald-300 shadow-xl transition-all duration-300"
        >
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
            <span><%= success_msg %></span>
        </div>
    <% } %>

    <% if (typeof error_msg !== 'undefined' && error_msg) { %>
        <div
            id="toast-error"
            class="fixed bottom-6 right-6 z-[110] flex max-w-sm items-center gap-2 rounded-lg border border-red-500/30 bg-red-950/90 px-4 py-3 text-xs text-red-300 shadow-xl transition-all duration-300"
        >
            <span class="h-1.5 w-1.5 rounded-full bg-red-400"></span>
            <span><%= error_msg %></span>
        </div>
    <% } %>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            ['toast-success', 'toast-error'].forEach(function (toastId) {
                const toast = document.getElementById(toastId);
                if (!toast) return;

                window.setTimeout(function () {
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateY(8px)';

                    window.setTimeout(function () {
                        toast.remove();
                    }, 300);
                }, 4500);
            });

            const modal = document.getElementById('delete-confirm-modal');
            const card = document.getElementById('delete-confirm-card');
            const cancelButton = document.getElementById('delete-confirm-cancel');
            const confirmButton = document.getElementById('delete-confirm-submit');
            const messageElement = document.getElementById('delete-confirm-message');
            const errorElement = document.getElementById('delete-confirm-error');

            if (!modal || !card || !cancelButton || !confirmButton || !messageElement || !errorElement) {
                return;
            }

            let activeDeleteForm = null;
            let requestController = null;

            function setBusy(isBusy) {
                confirmButton.disabled = isBusy;
                cancelButton.disabled = isBusy;

                if (isBusy) {
                    confirmButton.innerHTML = `
                        <svg class="h-3.5 w-3.5 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                        </svg>
                        <span>Deleting...</span>
                    `;
                } else {
                    confirmButton.textContent = 'Confirm Delete';
                }
            }

            function showModal(form) {
                activeDeleteForm = form;
                errorElement.classList.add('hidden');
                errorElement.textContent = '';

                const customMessage =
                    form.dataset.deleteMessage ||
                    form.querySelector('[data-delete-message]')?.dataset.deleteMessage ||
                    'Are you sure you want to delete this record? This action cannot be undone.';

                messageElement.textContent = customMessage;
                setBusy(false);

                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.body.style.overflow = 'hidden';

                window.requestAnimationFrame(function () {
                    modal.classList.add('opacity-100');
                    card.classList.remove('scale-95');
                    card.classList.add('scale-100');
                    cancelButton.focus();
                });
            }

            function closeModal(force) {
                if (confirmButton.disabled && !force) return;

                if (requestController && force) {
                    requestController.abort();
                    requestController = null;
                }

                card.classList.remove('scale-100');
                card.classList.add('scale-95');
                modal.classList.remove('opacity-100');
                document.body.style.overflow = '';

                window.setTimeout(function () {
                    modal.classList.remove('flex');
                    modal.classList.add('hidden');
                    activeDeleteForm = null;
                    errorElement.classList.add('hidden');
                    errorElement.textContent = '';
                    setBusy(false);
                }, 200);
            }

            function showDeleteError(message) {
                errorElement.textContent = message || 'Delete request failed. Please try again.';
                errorElement.classList.remove('hidden');
                setBusy(false);
            }

            document.addEventListener(
                'submit',
                function (event) {
                    const form = event.target;

                    if (!(form instanceof HTMLFormElement)) return;

                    const action = String(form.getAttribute('action') || '');

                    if (!action.includes('/delete')) return;

                    event.preventDefault();
                    event.stopImmediatePropagation();
                    showModal(form);
                },
                true
            );

            cancelButton.addEventListener('click', function () {
                closeModal(false);
            });

            modal.addEventListener('click', function (event) {
                if (event.target === modal) {
                    closeModal(false);
                }
            });

            document.addEventListener('keydown', function (event) {
                if (
                    event.key === 'Escape' &&
                    !modal.classList.contains('hidden') &&
                    !confirmButton.disabled
                ) {
                    closeModal(false);
                }
            });

            confirmButton.addEventListener('click', async function () {
                if (!activeDeleteForm || confirmButton.disabled) return;

                setBusy(true);
                errorElement.classList.add('hidden');
                errorElement.textContent = '';

                const form = activeDeleteForm;
                const action = form.action;
                const method = String(form.method || 'POST').toUpperCase();
                const formData = new FormData(form);
                const body = new URLSearchParams();

                formData.forEach(function (value, key) {
                    if (typeof value === 'string') {
                        body.append(key, value);
                    }
                });

                requestController = new AbortController();
                const timeoutId = window.setTimeout(function () {
                    requestController?.abort();
                }, 20000);

                try {
                    const response = await fetch(action, {
                        method: method,
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                            'Accept': 'text/html,application/json'
                        },
                        body: method === 'GET' ? undefined : body.toString(),
                        credentials: 'same-origin',
                        redirect: 'follow',
                        signal: requestController.signal
                    });

                    window.clearTimeout(timeoutId);
                    requestController = null;

                    if (response.redirected) {
                        window.location.assign(response.url);
                        return;
                    }

                    if (!response.ok) {
                        const responseText = (await response.text()).trim();
                        throw new Error(
                            responseText ||
                            `Delete request failed with status ${response.status}.`
                        );
                    }

                    window.location.reload();
                } catch (error) {
                    window.clearTimeout(timeoutId);
                    requestController = null;

                    if (error && error.name === 'AbortError') {
                        showDeleteError(
                            'Delete request timed out. Please check the server and try again.'
                        );
                        return;
                    }

                    console.error('Delete request failed:', error);
                    showDeleteError(
                        error?.message || 'Delete request failed. Please try again.'
                    );
                }
            });
        });
    </script>
</body>
</html>
