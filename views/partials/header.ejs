<!doctype html>
<html lang="en" class="h-full bg-[#0A0A0A]">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof title !== 'undefined' ? title : "PK Rentals - Rental Management System" %></title>
    <!-- Resource Hints for Faster Resource Loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.tailwindcss.com" />
    
    <!-- Stable & Optimized Tailwind CSS CDN (Instant Compile, No WASM Lag) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // Optional Tailwind CSS Configuration to customize theme styles just in case
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    }
                }
            }
        }
    </script>
    <script>
        // High-performance Instant Theme Preloader to prevent any white/dark flash
        (function() {
            try {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'light') {
                    document.documentElement.classList.add('light');
                } else {
                    document.documentElement.classList.remove('light');
                }
            } catch (e) {}
        })();
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;550&display=swap" rel="stylesheet" />
    <style>
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: #0A0A0A;
            color: #D4D4D8;
        }
        .font-mono {
            font-family: 'JetBrains Mono', monospace;
        }
        /* Custom scrollbar for modern visual sleekness */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #111111;
        }
        ::-webkit-scrollbar-thumb {
            background: #262626;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #3F3F46;
        }

        /* -----------------------------------------
           RESPONSIVE MOBILE TABLES CARDS & SCROLLBARS
           ----------------------------------------- */
        @media (max-width: 1024px) {
            div:has(> table) {
                overflow-x: auto !important;
                -webkit-overflow-scrolling: touch;
            }
            table {
                min-width: 750px !important;
            }
        }

        @media (max-width: 768px) {
            header {
                height: auto !important;
                padding-top: 1rem !important;
                padding-bottom: 1rem !important;
                padding-left: 1.25rem !important;
                padding-right: 1.25rem !important;
                flex-direction: column !important;
                align-items: flex-start !important;
                gap: 0.75rem !important;
            }
            header > div {
                width: 100% !important;
            }
            header .flex {
                flex-wrap: wrap !important;
                gap: 0.5rem !important;
                width: 100% !important;
            }
            header .w-px, header div.w-px {
                display: none !important;
            }
            .p-8, .p-6 {
                padding: 1.25rem !important;
            }
            .space-y-8 > :not([hidden]) ~ :not([hidden]) {
                --tw-space-y-reverse: 0;
                margin-top: 1.25rem !important;
                margin-bottom: 1.25rem !important;
            }
        }

        /* -----------------------------------------
           LIGHT MODE OVERRIDES AND COMPATIBILITY
           ----------------------------------------- */
        html.light, html.light body {
            background-color: #F8FAFC !important;
            color: #1E293B !important;
        }
        html.light #app-container {
            background-color: #F8FAFC !important;
        }

        /* Sidebar Overrides */
        html.light aside {
            background-color: #FFFFFF !important;
            border-right: 1px solid #E2E8F0 !important;
        }
        html.light aside div, html.light aside nav {
            border-color: #E2E8F0 !important;
        }
        html.light aside a {
            color: #475569 !important;
        }
        html.light aside a:hover {
            color: #0F172A !important;
            background-color: #F1F5F9 !important;
            border-color: #E2E8F0 !important;
        }
        /* Active nav item */
        html.light aside a.bg-\[\#161616\] {
            background-color: #F1F5F9 !important;
            color: #0F172A !important;
            border-color: #CBD5E1 !important;
        }
        html.light aside span.text-zinc-400 {
            color: #475569 !important;
        }
        html.light aside span.text-zinc-500 {
            color: #64748B !important;
        }
        html.light aside a span.text-blue-400 {
            color: #2563EB !important;
        }
        html.light aside .bg-\[\#0E0E0E\] {
            background-color: #F8FAFC !important;
            border-top-color: #E2E8F0 !important;
        }
        html.light aside .text-white {
            color: #0F172A !important;
        }
        html.light aside button#theme-toggle {
            color: #475569 !important;
        }
        html.light aside button#theme-toggle:hover {
            background-color: #F1F5F9 !important;
            color: #0F172A !important;
        }

        /* Mobile top bar overrides */
        html.light #mobile-top-bar {
            background-color: #FFFFFF !important;
            border-color: #E2E8F0 !important;
        }
        html.light #mobile-top-bar button {
            color: #475569 !important;
        }
        html.light #mobile-top-bar div {
            color: #0F172A !important;
        }

        /* Main Headers */
        html.light header {
            background-color: #FFFFFF !important;
            border-bottom: 1px solid #E2E8F0 !important;
        }
        html.light header span.text-zinc-200 {
            color: #0F172A !important;
        }
        html.light header span.text-zinc-500 {
            color: #64748B !important;
        }

        /* Dashboard & Common Cards */
        html.light .bg-\[\#111111\] {
            background-color: #FFFFFF !important;
            border-color: #E2E8F0 !important;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px -1px rgba(0, 0, 0, 0.05) !important;
        }
        html.light .bg-\[\#161616\] {
            background-color: #F8FAFC !important;
            border-color: #E2E8F0 !important;
        }
        /* Borders of items */
        html.light .border-\[\#1F1F1F\], 
        html.light .border-\[\#262626\],
        html.light .border-zinc-800,
        html.light .border-zinc-900 {
            border-color: #E2E8F0 !important;
        }
        html.light .divide-\[\#1F1F1F\] > * {
            border-color: #E2E8F0 !important;
        }
        html.light .divide-zinc-800 > * {
            border-color: #E2E8F0 !important;
        }

        /* Text states */
        html.light .text-white {
            color: #0F172A !important;
        }
        html.light .text-zinc-100 {
            color: #1E293B !important;
        }
        html.light .text-zinc-200 {
            color: #334155 !important;
        }
        html.light .text-zinc-300 {
            color: #475569 !important;
        }
        html.light .text-zinc-400 {
            color: #64748B !important;
        }
        html.light .text-zinc-500 {
            color: #94A3B8 !important;
        }
        html.light .hover\:text-white:hover {
            color: #0F172A !important;
        }
        html.light .hover\:bg-\[\#161616\]\/20:hover {
            background-color: rgba(241, 245, 249, 0.6) !important;
        }

        /* Forms, inputs, selectors */
        html.light input,
        html.light select,
        html.light textarea {
            background-color: #FFFFFF !important;
            border: 1px solid #CBD5E1 !important;
            color: #0F172A !important;
        }
        html.light input:focus,
        html.light select:focus,
        html.light textarea:focus {
            border-color: #3B82F6 !important;
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1) !important;
        }
        html.light input[readonly] {
            background-color: #F1F5F9 !important;
            border-color: #E2E8F0 !important;
            color: #64748B !important;
        }
        html.light select:disabled {
            background-color: #F1F5F9 !important;
            border-color: #E2E8F0 !important;
            color: #64748B !important;
        }

        /* Custom Badges / Boxes */
        html.light .bg-zinc-900 {
            background-color: #F1F5F9 !important;
            border-color: #CBD5E1 !important;
        }
        html.light .bg-zinc-950 {
            background-color: #F8FAFC !important;
            border-color: #CBD5E1 !important;
        }
        html.light .bg-\[\#0A0A0A\], html.light .bg-black {
            background-color: #F8FAFC !important;
        }
        html.light .bg-\[\#1A1A1A\] {
            background-color: #F1F5F9 !important;
            color: #0F172A !important;
        }
        html.light .bg-\[\#1C1C1E\] {
            background-color: #F1F5F9 !important;
            border-color: #E2E8F0 !important;
            color: #475569 !important;
        }
        html.light .bg-\[\#1C1C1E\]:hover {
            background-color: #E2E8F0 !important;
            color: #0F172A !important;
        }

        /* Table header cells */
        html.light thead tr.bg-\[\#161616\] {
            background-color: #F1F5F9 !important;
            color: #475569 !important;
        }
        html.light thead th {
            color: #475569 !important;
            font-weight: 600 !important;
        }

        /* Alerts */
        html.light .bg-red-950\/30 {
            background-color: #FEF2F2 !important;
            border-color: #FCA5A5 !important;
            color: #991B1B !important;
        }
        html.light .bg-emerald-950\/30 {
            background-color: #ECFDF5 !important;
            border-color: #6EE7B7 !important;
            color: #065F46 !important;
        }
        html.light .bg-emerald-950\/60 {
            background-color: #ECFDF5 !important;
            border-color: #A7F3D0 !important;
            color: #047857 !important;
        }
        html.light .bg-blue-950\/10 {
            background-color: #EFF6FF !important;
            border-color: #BFDBFE !important;
            color: #1E40AF !important;
        }
        html.light .text-blue-300 {
            color: #1D4ED8 !important;
        }
        html.light .text-blue-400 {
            color: #2563EB !important;

        }
        
    </style>
</head>
<body class="h-full flex text-zinc-300 antialiased overflow-hidden">
    <!-- Main Flex Wrapper -->
    <div id="app-container" class="flex flex-col md:flex-row w-full h-full overflow-hidden">
