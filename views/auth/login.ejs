
<!doctype html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - PK Rentals</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet"
    >

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="min-h-screen bg-[#080A0F] text-white antialiased">

    <main class="min-h-screen flex items-center justify-center px-4">

        <div class="w-full max-w-sm">

            <div class="text-center mb-6">
                <div class="w-14 h-14 mx-auto rounded-2xl bg-blue-600 flex items-center justify-center text-lg font-extrabold shadow-lg shadow-blue-950/40">
                    PK
                </div>

                <h1 class="mt-4 text-2xl font-extrabold tracking-tight">
                    PK Rentals
                </h1>
            </div>

            <div class="rounded-2xl border border-slate-800 bg-[#10141D] p-6 shadow-2xl">

                <% if (typeof error_msg !== 'undefined' && error_msg) { %>
                    <div class="mb-5 rounded-xl border border-red-500/25 bg-red-950/30 px-4 py-3 text-xs text-red-300">
                        <%= error_msg %>
                    </div>
                <% } %>

                <form
                    id="login-form"
                    action="/login"
                    method="POST"
                    class="space-y-4"
                >
                    <input
                        type="hidden"
                        id="username"
                        name="username"
                        value=""
                    >

                    <div>
                        <label
                            for="username-local"
                            class="block mb-2 text-xs font-semibold text-slate-400"
                        >
                            Gmail Address
                        </label>

                        <div class="flex overflow-hidden rounded-xl border border-slate-700 bg-[#080A0F] focus-within:border-blue-500 focus-within:ring-2 focus-within:ring-blue-500/15">

                            <input
                                type="text"
                                id="username-local"
                                required
                                autocomplete="username"
                                placeholder="admin"
                                class="min-w-0 flex-1 bg-transparent px-4 py-3 text-sm text-white outline-none placeholder:text-slate-600"
                            >

                            <div class="flex items-center border-l border-slate-700 bg-slate-900 px-3 text-xs font-semibold text-slate-400 select-none">
                                @gmail.com
                            </div>
                        </div>
                    </div>

                    <div>
                        <label
                            for="password"
                            class="block mb-2 text-xs font-semibold text-slate-400"
                        >
                            Password
                        </label>

                        <div class="relative">
                            <input
                                type="password"
                                id="password"
                                name="password"
                                required
                                autocomplete="current-password"
                                placeholder="Enter password"
                                class="w-full rounded-xl border border-slate-700 bg-[#080A0F] px-4 py-3 pr-16 text-sm text-white outline-none transition placeholder:text-slate-600 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/15"
                            >

                            <button
                                type="button"
                                id="toggle-password"
                                class="absolute right-3 top-1/2 -translate-y-1/2 rounded-md px-2 py-1 text-[11px] font-semibold text-slate-500 hover:bg-white/5 hover:text-white"
                            >
                                Show
                            </button>
                        </div>
                    </div>

                    <button
                        id="login-button"
                        type="submit"
                        class="w-full rounded-xl bg-blue-600 py-3 text-sm font-bold text-white transition hover:bg-blue-500 active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-60"
                    >
                        Login
                    </button>
                </form>

            </div>

        </div>

    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('login-form');
            const localInput = document.getElementById('username-local');
            const hiddenUsername = document.getElementById('username');
            const passwordInput = document.getElementById('password');
            const togglePassword = document.getElementById('toggle-password');
            const loginButton = document.getElementById('login-button');

            if (
                !form ||
                !localInput ||
                !hiddenUsername ||
                !passwordInput ||
                !loginButton
            ) {
                return;
            }

            localInput.addEventListener('input', function () {
                let value = String(localInput.value || '')
                    .trim()
                    .toLowerCase();

                if (value.includes('@')) {
                    value = value.split('@')[0];
                }

                value = value.replace(/[^a-z0-9._%+-]/g, '');
                localInput.value = value;
            });

            if (togglePassword) {
                togglePassword.addEventListener('click', function () {
                    const isHidden = passwordInput.type === 'password';

                    passwordInput.type = isHidden ? 'text' : 'password';
                    togglePassword.textContent = isHidden ? 'Hide' : 'Show';
                });
            }

            form.addEventListener('submit', function (event) {
                const localPart = String(localInput.value || '')
                    .trim()
                    .toLowerCase()
                    .replace(/@gmail\.com$/i, '')
                    .split('@')[0];

                if (!localPart) {
                    event.preventDefault();
                    localInput.setCustomValidity('Please enter your Gmail username.');
                    localInput.reportValidity();
                    localInput.focus();
                    return;
                }

                localInput.setCustomValidity('');
                hiddenUsername.value = localPart + '@gmail.com';

                loginButton.disabled = true;
                loginButton.innerHTML = `
                    <span class="inline-flex items-center justify-center gap-2">
                        <svg
                            class="h-4 w-4 animate-spin"
                            viewBox="0 0 24 24"
                            fill="none"
                            aria-hidden="true"
                        >
                            <circle
                                class="opacity-25"
                                cx="12"
                                cy="12"
                                r="10"
                                stroke="currentColor"
                                stroke-width="4"
                            ></circle>

                            <path
                                class="opacity-75"
                                fill="currentColor"
                                d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"
                            ></path>
                        </svg>

                        Logging in...
                    </span>
                `;
            });
        });
    </script>

</body>
</html>
```
