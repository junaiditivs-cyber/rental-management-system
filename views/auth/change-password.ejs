<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div>
            <h1 class="text-white text-lg font-bold">Change Password</h1>
            <p class="text-zinc-500 text-xs">Update your own login password.</p>
        </div>

        <a href="/" class="px-4 py-2 bg-[#1C1C1E] text-zinc-300 text-xs font-semibold rounded border border-[#2E2E30] hover:text-white transition-colors">
            Back
        </a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto">
        <form action="/change-password" method="POST" class="max-w-xl bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-5">

            <% if (error_msg) { %>
                <div class="bg-red-950/30 border border-red-700 text-red-300 px-4 py-3 rounded text-sm">
                    <%= error_msg %>
                </div>
            <% } %>

            <% if (success_msg) { %>
                <div class="bg-emerald-950/30 border border-emerald-700 text-emerald-300 px-4 py-3 rounded text-sm">
                    <%= success_msg %>
                </div>
            <% } %>

            <div>
                <label class="block text-xs font-bold text-zinc-400 uppercase mb-2">Current Password</label>
                <input 
                    type="password" 
                    name="current_password" 
                    required 
                    class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded text-white text-sm"
                    placeholder="Enter current password"
                >
            </div>

            <div>
                <label class="block text-xs font-bold text-zinc-400 uppercase mb-2">New Password</label>
                <input 
                    type="password" 
                    name="new_password" 
                    required 
                    minlength="6"
                    class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded text-white text-sm"
                    placeholder="Enter new password"
                >
                <p class="text-zinc-500 text-[11px] mt-1">Minimum 6 characters.</p>
            </div>

            <div>
                <label class="block text-xs font-bold text-zinc-400 uppercase mb-2">Confirm New Password</label>
                <input 
                    type="password" 
                    name="confirm_password" 
                    required 
                    minlength="6"
                    class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded text-white text-sm"
                    placeholder="Confirm new password"
                >
            </div>

            <button type="submit" class="px-5 py-2 bg-white text-black text-sm font-bold rounded hover:bg-zinc-200 transition-colors">
                Change Password
            </button>
        </form>
    </div>
</main>

<%- include('../partials/footer') %>