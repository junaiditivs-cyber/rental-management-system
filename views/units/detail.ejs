<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">
            Units &gt; <a href="/properties/<%= unit.property_id %>" class="hover:text-blue-400 font-medium underline"><%= unit.property_name %></a> &gt; <span class="text-zinc-200"><%= unit.name %> details</span>
        </div>
        <div class="flex gap-2">
            <a href="/units/<%= unit.id %>/edit" class="px-4 py-1.5 bg-[#1C1C1E] border border-zinc-800 text-zinc-300 text-xs font-semibold rounded hover:text-white transition-colors">
                Edit Unit Specifications
            </a>
            <form action="/units/<%= unit.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Do you want to delete this rentable unit box?');">
                <button type="submit" class="px-4 py-1.5 bg-red-950/20 border border-red-900/30 text-red-400 text-xs font-semibold rounded hover:bg-red-900/40 transition-colors">
                    Remove Unit Box
                </button>
            </form>
        </div>
    </header>

    <!-- Content panel -->
    <div class="p-8 flex-1 overflow-y-auto space-y-8">
        
        <!-- Unit Info Display & Status Alert Banner -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Left Info Block -->
            <div class="lg:col-span-2 bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-4 shadow-lg">
                <div class="flex justify-between items-start">
                    <div>
                        <span class="px-2 py-0.5 bg-[#1C1C1E] border border-[#2E2E30] text-[9px] font-mono rounded text-zinc-400 font-bold uppercase tracking-wider">
                            <%= unit.unit_type %> Unit Type
                        </span>
                        <h1 class="text-white text-2xl font-black tracking-tight mt-1">Unit Name: <%= unit.name %></h1>
                        <p class="text-zinc-500 text-xs">Installed inside <strong class="text-zinc-300"><%= unit.property_name %></strong> &bull; Level: <strong class="text-zinc-300 capitalize"><%= unit.floor_name %></strong></p>
                    </div>

                    <!-- Large Colored Status Indicator -->
                    <% 
                      let statusBg = "";
                      let statusText = "";
                      if (unit.status.toLowerCase() === 'rented') {
                        statusBg = "bg-emerald-950/65 border-emerald-500/30 text-emerald-400";
                        statusText = "Occupied";
                      } else if (unit.status.toLowerCase() === 'vacant') {
                        statusBg = "bg-red-950/65 border-red-500/30 text-red-500";
                        statusText = "Vacant";
                      } else {
                        statusBg = "bg-amber-950/65 border-amber-500/30 text-amber-500";
                        statusText = "Rent Pending / Partial";
                      }
                    %>
                    <div class="px-4 py-2 border rounded-xl text-center select-none shadow-md <%= statusBg %>">
                        <div class="text-[9px] font-black uppercase tracking-wider opacity-60">Status</div>
                        <div class="text-sm font-bold font-mono mt-0.5"><%= statusText %></div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4 border-t border-[#1F1F1F]">
                    <div class="bg-[#161616] p-4 rounded-lg border border-[#262626]">
                        <div class="text-[10px] uppercase font-bold text-zinc-500">Target Monthly Rent</div>
                        <div class="text-xl font-bold font-mono text-zinc-100 mt-1">₨ <%= unit.rent_amount.toLocaleString() %></div>
                    </div>
                    <div class="bg-[#161616] p-4 rounded-lg border border-[#262626]">
                        <div class="text-[10px] uppercase font-bold text-zinc-500">Target Security Advance</div>
                        <div class="text-xl font-bold font-mono text-zinc-100 mt-1">₨ <%= unit.advance_amount.toLocaleString() %></div>
                    </div>
                </div>

                <% if (unit.notes) { %>
                    <div class="pt-2">
                        <h4 class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider mb-1">Unit Access Notes / Sub-Meters</h4>
                        <p class="text-zinc-400 text-xs leading-relaxed bg-zinc-950 p-3 rounded-md border border-zinc-900"><%= unit.notes %></p>
                    </div>
                <% } %>
            </div>

            <!-- Right interactive Action Panel depending on status -->
            <div class="lg:col-span-1 bg-[#111111] border border-[#262626] rounded-xl p-6 flex flex-col justify-between shadow-lg">
                <% if (unit.status.toLowerCase() === 'vacant') { %>
                    <!-- Vacant actions -->
                    <div class="space-y-4">
                        <div class="text-center py-6 border border-dashed border-zinc-800 rounded-lg bg-zinc-950/40">
                            <span class="w-10 h-10 rounded-full bg-red-950/40 border border-red-500/20 text-red-400 flex items-center justify-center mx-auto text-lg font-bold">!</span>
                            <h3 class="text-white text-sm font-semibold mt-3">Ready to be Leased</h3>
                            <p class="text-zinc-550 text-[11px] px-4 mt-1">This unit is currently vacant. You can link a tenant profile by creating a rent agreement.</p>
                        </div>
                        
                        <a href="/agreements/add?unit_id=<%= unit.id %>" class="block w-full py-2.5 bg-white text-black hover:bg-zinc-200 text-xs font-bold text-center rounded-md transition-all">
                            Initialize Rent Agreement
                        </a>
                    </div>
                <% } else { %>
                    <!-- Occupied actions (Active lease details) -->
                    <div class="space-y-4">
                        <div class="p-4 bg-emerald-950/15 border border-emerald-500/10 rounded-lg">
                            <h3 class="text-emerald-400 text-xs font-bold uppercase tracking-wider">Active Occupancy details</h3>
                            
                            <% if (activeAgreement) { %>
                                <div class="mt-3 space-y-2 text-xs">
                                    <div class="flex justify-between py-1 border-b border-[#262626]/45">
                                        <span class="text-zinc-500">Tenant Parent:</span>
                                        <a href="/tenants/<%= activeAgreement.tenant_id %>" class="text-white hover:text-blue-400 font-semibold underline decoration-dotted"><%= activeAgreement.tenant_name %></a>
                                    </div>
                                    <div class="flex justify-between py-1 border-b border-[#262626]/45">
                                        <span class="text-zinc-500">Agreement Term:</span>
                                        <span class="text-zinc-300 font-mono"><%= activeAgreement.start_date %> to <%= activeAgreement.end_date %></span>
                                    </div>
                                    <div class="flex justify-between py-1 border-b border-[#262626]/45">
                                        <span class="text-zinc-500">Due Day:</span>
                                        <span class="text-zinc-300 font-mono">Day <%= activeAgreement.due_day %> of month</span>
                                    </div>
                                    <div class="flex justify-between py-1 border-b border-[#262626]/45">
                                        <span class="text-zinc-500">Advance Security:</span>
                                        <span class="text-zinc-300 font-mono font-bold">₨ <%= activeAgreement.advance_amount.toLocaleString() %></span>
                                    </div>
                                </div>
                            <% } %>
                        </div>

                        <!-- Collection quick shortcuts -->
                        <div class="space-y-2 pt-2">
                            <a href="/rent/collect?unit_id=<%= unit.id %>" class="block w-full py-2 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold text-center rounded-md transition-all">
                                Collect Monthly Rent Payment
                            </a>
                            <a href="/agreements/<%= activeAgreement.id %>/end" onclick="return confirm('Do you want to end this lease and discharge the tenant?');" class="block w-full py-2 bg-zinc-900 border border-zinc-800 hover:bg-zinc-850 text-red-400 text-xs font-semibold text-center rounded-md transition-all">
                                Terminate &amp; Discharge Tenant
                            </a>
                        </div>
                    </div>
                <% } %>
                <div class="text-[10px] text-zinc-500 text-center font-mono mt-4">Node Hash: <%= unit.id %></div>
            </div>

        </div>

        <!-- Section: Active Tenant Profile Card (if rented) -->
        <% if (unit.status.toLowerCase() !== 'vacant' && activeAgreement) { %>
            <div class="bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-4 shadow-lg">
                <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest border-b border-[#1F1F1F] pb-2">Active Tenant Profile Details</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">Tenant Name</div>
                        <div class="text-sm font-semibold text-white mt-1"><%= activeAgreement.tenant_name %></div>
                    </div>
                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">Father's Name</div>
                        <div class="text-sm font-semibold text-white mt-1"><%= activeAgreement.tenant_father_name %></div>
                    </div>
                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">CNIC Card Number</div>
                        <div class="text-sm font-semibold text-white font-mono mt-1"><%= activeAgreement.tenant_cnic %></div>
                    </div>
                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">Mobile Phone</div>
                        <div class="text-sm font-semibold text-white font-mono mt-1"><%= activeAgreement.tenant_phone %></div>
                    </div>
                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">Emergency Contact Link</div>
                        <div class="text-sm font-semibold text-white mt-1"><%= activeAgreement.tenant_emergency || 'N/A' %></div>
                    </div>
                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">Agreement Documents</div>
                        <div class="text-xs mt-1 text-zinc-400">
                            <% if (activeAgreement.agreement_doc_url) { %>
                                <a href="<%= activeAgreement.agreement_doc_url %>" target="_blank" class="text-blue-400 font-bold hover:underline" referrerpolicy="no-referrer">Download Agreement File &darr;</a>
                            <% } else { %>
                                <span class="zinc-600">No agreement document uploaded</span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Historical ledger logs -->
        <div class="space-y-4">
            <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest">Rent Payment History Ledger</h3>
            <div class="bg-[#111111] border border-[#262626] rounded-xl overflow-hidden shadow-lg">
                <table class="w-full text-left border-collapse text-xs font-mono">
                    <thead>
                        <tr class="border-b border-[#1F1F1F] bg-[#161616] text-[10px] font-bold text-zinc-500 uppercase tracking-wider font-sans">
                            <th class="p-4">Paid On</th>
                            <th class="p-4">Period</th>
                            <th class="p-4">Monthly Rate</th>
                            <th class="p-4">Collected Cash</th>
                            <th class="p-4">Outstanding Arrears</th>
                            <th class="p-4">Gateway</th>
                            <th class="p-4">Status</th>
                            <th class="p-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#1F1F1F] text-zinc-300">
                        <% if (payments && payments.length > 0) { %>
                            <% payments.forEach(p => { %>
                                <tr>
                                    <td class="p-4 font-sans"><%= p.payment_date %></td>
                                    <td class="p-4 text-zinc-200">Month: <%= p.rent_month %> Year: <%= p.rent_year %></td>
                                    <td class="p-4 text-zinc-400">₨ <%= p.total_rent.toLocaleString() %></td>
                                    <td class="p-4 text-emerald-400 font-bold">₨ <%= p.paid_amount.toLocaleString() %></td>
                                    <td class="p-4 text-red-400">₨ <%= p.pending_amount.toLocaleString() %></td>
                                    <td class="p-4 font-sans text-zinc-400 capitalize"><%= p.payment_method %></td>
                                    <td class="p-4 font-sans font-bold">
                                        <% if(p.status.toLowerCase() === 'paid') { %>
                                            <span class="text-emerald-400 text-[10px] bg-emerald-950/40 border border-emerald-900/30 px-2 py-0.5 rounded">Paid</span>
                                        <% } else if(p.status.toLowerCase() === 'partial') { %>
                                            <span class="text-amber-400 text-[10px] bg-amber-950/40 border border-[#452D12]/30 px-1.5 py-0.5 rounded">Partial</span>
                                        <% } else { %>
                                            <span class="text-red-400 text-[10px] bg-red-950/40 border border-red-900/30 px-2 py-0.5 rounded">Unpaid</span>
                                        <% } %>
                                    </td>
                                    <td class="p-4 text-right font-sans space-x-1 whitespace-nowrap">
                                        <a href="/rent/<%= p.id %>/edit" class="text-[10px] text-zinc-300 hover:text-white bg-[#1A1A1C] border border-zinc-805 px-2 py-0.5 rounded font-sans inline-block">
                                            Edit
                                        </a>
                                        <form action="/rent/<%= p.id %>/delete" method="POST" class="inline" onsubmit="return confirm('WARNING: Are you sure you want to delete this payment record? This will permanently erase the transaction from historical ledgers.');">
                                            <button type="submit" class="text-[10px] text-red-400 hover:text-red-300 bg-red-950/20 border border-red-900/30 px-2 py-0.5 rounded font-sans">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="p-8 text-center text-zinc-550 font-sans">
                                    No historical payment entries saved for this rental unit box.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</main>

<%- include('../partials/footer') %>
