<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<%
    const unitStatus = String(unit?.status || 'vacant').toLowerCase();

    let statusBg = '';
    let statusText = '';

    if (unitStatus === 'rented') {
        statusBg = 'bg-emerald-950/65 border-emerald-500/30 text-emerald-400';
        statusText = 'Occupied';
    } else if (unitStatus === 'vacant') {
        statusBg = 'bg-red-950/65 border-red-500/30 text-red-500';
        statusText = 'Vacant';
    } else {
        statusBg = 'bg-amber-950/65 border-amber-500/30 text-amber-500';
        statusText = 'Rent Pending / Partial';
    }

    const paymentList = Array.isArray(payments) ? payments : [];

    const pendingPartialPayments = paymentList.filter(
        payment => Number(payment.pending_amount || 0) > 0
    );
%>

<main class="flex-1 flex flex-col h-full overflow-hidden">

    <!-- Header -->
    <header class="min-h-16 border-b border-[#1F1F1F] px-5 lg:px-8 py-3 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3 shrink-0">

        <div class="text-sm text-zinc-500">
            Units &gt;

            <a href="/properties/<%= unit.property_id %>"
               class="hover:text-blue-400 font-medium underline">
                <%= unit.property_name %>
            </a>

            &gt;

            <span class="text-zinc-200">
                <%= unit.name %> details
            </span>
        </div>

        <div class="flex flex-wrap items-center gap-2">

            <a href="/units/<%= unit.id %>/edit"
               class="px-4 py-2 bg-[#1C1C1E] border border-zinc-800 text-zinc-300 text-xs font-semibold rounded-lg hover:bg-zinc-800 hover:text-white transition-colors">
                Edit Unit Specifications
            </a>

            <form action="/units/<%= unit.id %>/delete"
                  method="POST"
                  class="inline"
                  onsubmit="return confirm('Do you want to delete this rentable unit box?');">

                <button type="submit"
                        class="px-4 py-2 bg-red-950/20 border border-red-900/30 text-red-400 text-xs font-semibold rounded-lg hover:bg-red-900/40 hover:text-red-300 transition-colors">
                    Remove Unit Box
                </button>
            </form>

        </div>
    </header>

    <!-- Content -->
    <div class="p-5 lg:p-8 flex-1 overflow-y-auto space-y-8">

        <!-- Unit Information -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Main Unit Information -->
            <div class="lg:col-span-2 bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-4 shadow-lg">

                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">

                    <div>
                        <span class="inline-flex px-2 py-0.5 bg-[#1C1C1E] border border-[#2E2E30] text-[9px] font-mono rounded text-zinc-400 font-bold uppercase tracking-wider">
                            <%= unit.unit_type || 'Unit' %> Unit Type
                        </span>

                        <h1 class="text-white text-2xl font-black tracking-tight mt-2">
                            Unit Name: <%= unit.name %>
                        </h1>

                        <p class="text-zinc-500 text-xs mt-1">
                            Installed inside
                            <strong class="text-zinc-300">
                                <%= unit.property_name %>
                            </strong>

                            &bull; Level:

                            <strong class="text-zinc-300 capitalize">
                                <%= unit.floor_name %>
                            </strong>
                        </p>
                    </div>

                    <!-- Status -->
                    <div class="px-4 py-2 border rounded-xl text-center select-none shadow-md <%= statusBg %>">
                        <div class="text-[9px] font-black uppercase tracking-wider opacity-60">
                            Status
                        </div>

                        <div class="text-sm font-bold font-mono mt-0.5">
                            <%= statusText %>
                        </div>
                    </div>

                </div>

                <!-- Rent and Advance -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4 border-t border-[#1F1F1F]">

                    <div class="bg-[#161616] p-4 rounded-lg border border-[#262626]">
                        <div class="text-[10px] uppercase font-bold text-zinc-500">
                            Target Monthly Rent
                        </div>

                        <div class="text-xl font-bold font-mono text-zinc-100 mt-1">
                            ₨ <%= Number(unit.rent_amount || 0).toLocaleString() %>
                        </div>
                    </div>

                    <div class="bg-[#161616] p-4 rounded-lg border border-[#262626]">
                        <div class="text-[10px] uppercase font-bold text-zinc-500">
                            Target Security Advance
                        </div>

                        <div class="text-xl font-bold font-mono text-zinc-100 mt-1">
                            ₨ <%= Number(unit.advance_amount || 0).toLocaleString() %>
                        </div>
                    </div>

                </div>

                <!-- Notes -->
                <% if (unit.notes) { %>
                    <div class="pt-2">
                        <h4 class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider mb-1">
                            Unit Access Notes / Sub-Meters
                        </h4>

                        <p class="text-zinc-400 text-xs leading-relaxed bg-zinc-950 p-3 rounded-md border border-zinc-900 whitespace-pre-line">
                            <%= unit.notes %>
                        </p>
                    </div>
                <% } %>

            </div>

            <!-- Unit Actions -->
            <div class="lg:col-span-1 bg-[#111111] border border-[#262626] rounded-xl p-6 flex flex-col justify-between shadow-lg">

                <% if (unitStatus === 'vacant') { %>

                    <!-- Vacant Unit -->
                    <div class="space-y-4">

                        <div class="text-center py-6 border border-dashed border-zinc-800 rounded-lg bg-zinc-950/40">

                            <span class="w-10 h-10 rounded-full bg-red-950/40 border border-red-500/20 text-red-400 flex items-center justify-center mx-auto text-lg font-bold">
                                !
                            </span>

                            <h3 class="text-white text-sm font-semibold mt-3">
                                Ready to be Leased
                            </h3>

                            <p class="text-zinc-500 text-[11px] px-4 mt-1 leading-relaxed">
                                This unit is currently vacant. You can link a tenant profile by creating a rent agreement.
                            </p>

                        </div>

                        <a href="/agreements/add?unit_id=<%= unit.id %>"
                           class="block w-full py-2.5 bg-white text-black hover:bg-zinc-200 text-xs font-bold text-center rounded-md transition-all">
                            Initialize Rent Agreement
                        </a>

                    </div>

                <% } else { %>

                    <!-- Occupied or Pending Unit -->
                    <div class="space-y-4">

                        <div class="p-4 bg-emerald-950/15 border border-emerald-500/10 rounded-lg">

                            <h3 class="text-emerald-400 text-xs font-bold uppercase tracking-wider">
                                Active Occupancy Details
                            </h3>

                            <% if (activeAgreement) { %>

                                <div class="mt-3 space-y-2 text-xs">

                                    <div class="flex justify-between gap-3 py-1 border-b border-[#262626]/45">
                                        <span class="text-zinc-500">
                                            Tenant:
                                        </span>

                                        <a href="/tenants/<%= activeAgreement.tenant_id %>"
                                           class="text-white hover:text-blue-400 font-semibold underline decoration-dotted text-right">
                                            <%= activeAgreement.tenant_name %>
                                        </a>
                                    </div>

                                    <div class="flex justify-between gap-3 py-1 border-b border-[#262626]/45">
                                        <span class="text-zinc-500">
                                            Agreement Term:
                                        </span>

                                        <span class="text-zinc-300 font-mono text-right">
                                            <%= activeAgreement.start_date %>
                                            to
                                            <%= activeAgreement.end_date %>
                                        </span>
                                    </div>

                                    <div class="flex justify-between gap-3 py-1 border-b border-[#262626]/45">
                                        <span class="text-zinc-500">
                                            Due Day:
                                        </span>

                                        <span class="text-zinc-300 font-mono">
                                            Day <%= activeAgreement.due_day %>
                                        </span>
                                    </div>

                                    <div class="flex justify-between gap-3 py-1 border-b border-[#262626]/45">
                                        <span class="text-zinc-500">
                                            Advance Security:
                                        </span>

                                        <span class="text-zinc-300 font-mono font-bold">
                                            ₨ <%= Number(activeAgreement.advance_amount || 0).toLocaleString() %>
                                        </span>
                                    </div>

                                </div>

                            <% } else { %>

                                <div class="mt-3 p-3 bg-amber-950/20 border border-amber-500/20 rounded-md text-amber-300 text-xs leading-relaxed">
                                    Unit status is not vacant, but no active agreement was found.
                                </div>

                            <% } %>

                        </div>

                        <!-- Collection Actions -->
                        <div class="space-y-2 pt-2">

                            <% if (activeAgreement) { %>

                                <a href="/rent/collect?unit_id=<%= unit.id %>"
                                   class="block w-full py-2 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold text-center rounded-md transition-all">
                                    Collect Monthly Rent Payment
                                </a>

                                <a href="/agreements/<%= activeAgreement.id %>/end"
                                   onclick="return confirm('Do you want to end this lease and discharge the tenant?');"
                                   class="block w-full py-2 bg-zinc-900 border border-zinc-800 hover:bg-zinc-800 text-red-400 text-xs font-semibold text-center rounded-md transition-all">
                                    Terminate &amp; Discharge Tenant
                                </a>

                            <% } else { %>

                                <a href="/agreements/add?unit_id=<%= unit.id %>"
                                   class="block w-full py-2 bg-amber-600 hover:bg-amber-500 text-white text-xs font-bold text-center rounded-md transition-all">
                                    Create Missing Agreement
                                </a>

                            <% } %>

                        </div>

                    </div>

                <% } %>

                <div class="text-[10px] text-zinc-500 text-center font-mono mt-4 break-all">
                    Node Hash: <%= unit.id %>
                </div>

            </div>

        </div>

        <!-- Active Tenant Profile -->
        <% if (unitStatus !== 'vacant' && activeAgreement) { %>

            <div class="bg-[#111111] border border-[#262626] rounded-xl p-6 space-y-4 shadow-lg">

                <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest border-b border-[#1F1F1F] pb-2">
                    Active Tenant Profile Details
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">
                            Tenant Name
                        </div>

                        <div class="text-sm font-semibold text-white mt-1">
                            <%= activeAgreement.tenant_name || 'N/A' %>
                        </div>
                    </div>

                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">
                            Father's Name
                        </div>

                        <div class="text-sm font-semibold text-white mt-1">
                            <%= activeAgreement.tenant_father_name || 'N/A' %>
                        </div>
                    </div>

                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">
                            CNIC Card Number
                        </div>

                        <div class="text-sm font-semibold text-white font-mono mt-1">
                            <%= activeAgreement.tenant_cnic || 'N/A' %>
                        </div>
                    </div>

                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">
                            Mobile Phone
                        </div>

                        <div class="text-sm font-semibold text-white font-mono mt-1">
                            <%= activeAgreement.tenant_phone || 'N/A' %>
                        </div>
                    </div>

                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">
                            Emergency Contact
                        </div>

                        <div class="text-sm font-semibold text-white mt-1">
                            <%= activeAgreement.tenant_emergency || 'N/A' %>
                        </div>
                    </div>

                    <div>
                        <div class="text-[10px] text-zinc-500 uppercase font-bold">
                            Agreement Documents
                        </div>

                        <div class="text-xs mt-1 text-zinc-400">

                            <% if (activeAgreement.agreement_doc_url) { %>

                                <a href="<%= activeAgreement.agreement_doc_url %>"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="text-blue-400 font-bold hover:underline">
                                    Download Agreement File &darr;
                                </a>

                            <% } else { %>

                                <span class="text-zinc-600">
                                    No agreement document uploaded
                                </span>

                            <% } %>

                        </div>
                    </div>

                </div>

            </div>

        <% } %>

        <!-- Pending Partial Payments -->
        <% if (pendingPartialPayments.length > 0) { %>

            <div class="bg-amber-950/20 border border-amber-500/25 rounded-xl p-5 space-y-4 shadow-lg">

                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">

                    <div>
                        <h3 class="text-amber-300 text-sm font-bold uppercase tracking-wider">
                            Pending Partial Payments
                        </h3>

                        <p class="text-zinc-400 text-xs mt-1">
                            This unit has partial rent payments with remaining balances.
                        </p>
                    </div>

                    <span class="px-3 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-300 text-[10px] font-bold rounded-full uppercase tracking-wider">
                        <%= pendingPartialPayments.length %> Pending
                    </span>

                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">

                    <% pendingPartialPayments.forEach(payment => { %>

                        <div class="bg-[#111111] border border-[#262626] rounded-lg p-4">

                            <div class="flex items-start justify-between gap-3">

                                <div>
                                    <div class="text-[10px] text-zinc-500 uppercase font-bold tracking-wider">
                                        Month / Year
                                    </div>

                                    <div class="text-white text-sm font-bold mt-1">
                                        Month: <%= payment.rent_month %>
                                        &nbsp;
                                        Year: <%= payment.rent_year %>
                                    </div>
                                </div>

                                <span class="px-2 py-0.5 rounded bg-amber-950/40 border border-amber-900/40 text-amber-300 text-[10px] font-bold">
                                    Partial
                                </span>

                            </div>

                            <div class="grid grid-cols-3 gap-3 mt-4 pt-4 border-t border-[#262626]">

                                <div>
                                    <div class="text-[9px] text-zinc-500 uppercase font-bold">
                                        Paid On
                                    </div>

                                    <div class="text-zinc-200 text-xs font-mono mt-1">
                                        <%= payment.payment_date %>
                                    </div>
                                </div>

                                <div>
                                    <div class="text-[9px] text-emerald-500 uppercase font-bold">
                                        Paid
                                    </div>

                                    <div class="text-emerald-400 text-xs font-mono font-bold mt-1">
                                        ₨ <%= Number(payment.paid_amount || 0).toLocaleString() %>
                                    </div>
                                </div>

                                <div>
                                    <div class="text-[9px] text-red-400 uppercase font-bold">
                                        Pending
                                    </div>

                                    <div class="text-red-400 text-xs font-mono font-bold mt-1">
                                        ₨ <%= Number(payment.pending_amount || 0).toLocaleString() %>
                                    </div>
                                </div>

                            </div>

                            <% if (payment.notes) { %>

                                <div class="mt-3 bg-[#161616] border border-[#262626] rounded-md p-2">

                                    <div class="text-[9px] text-zinc-500 uppercase font-bold mb-1">
                                        Later Payment History
                                    </div>

                                    <div class="text-[11px] text-zinc-400 whitespace-pre-line leading-relaxed">
                                        <%= payment.notes %>
                                    </div>

                                </div>

                            <% } %>

                            <div class="mt-4">

                                <a href="/rent/<%= payment.id %>/partial"
                                   class="block w-full text-center py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-bold rounded-md transition-colors">
                                    Receive Pending Balance
                                </a>

                            </div>

                        </div>

                    <% }) %>

                </div>

            </div>

        <% } %>

        <!-- Payment History -->
        <div class="space-y-4">

            <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest">
                Rent Payment History Ledger
            </h3>

            <div class="bg-[#111111] border border-[#262626] rounded-xl overflow-x-auto shadow-lg">

                <table class="w-full min-w-[1100px] text-left border-collapse text-xs font-mono">

                    <thead>
                        <tr class="border-b border-[#1F1F1F] bg-[#161616] text-[10px] font-bold text-zinc-500 uppercase tracking-wider font-sans">
                            <th class="p-4">Paid On</th>
                            <th class="p-4">Period</th>
                            <th class="p-4">Monthly Rate</th>
                            <th class="p-4">Collected Cash</th>
                            <th class="p-4">Outstanding Arrears</th>
                            <th class="p-4">Gateway</th>
                            <th class="p-4">Status</th>
                            <th class="p-4">Partial History</th>
                            <th class="p-4 text-right">Actions</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-[#1F1F1F] text-zinc-300">

                        <% if (paymentList.length > 0) { %>

                            <% paymentList.forEach(payment => { %>

                                <%
                                    const paymentStatus = String(payment.status || '').toLowerCase();
                                %>

                                <tr class="hover:bg-white/[0.015] transition-colors">

                                    <td class="p-4 font-sans">
                                        <%= payment.payment_date %>
                                    </td>

                                    <td class="p-4 text-zinc-200">
                                        Month: <%= payment.rent_month %>
                                        Year: <%= payment.rent_year %>
                                    </td>

                                    <td class="p-4 text-zinc-400">
                                        ₨ <%= Number(payment.total_rent || 0).toLocaleString() %>
                                    </td>

                                    <td class="p-4 text-emerald-400 font-bold">
                                        ₨ <%= Number(payment.paid_amount || 0).toLocaleString() %>
                                    </td>

                                    <td class="p-4 text-red-400">
                                        ₨ <%= Number(payment.pending_amount || 0).toLocaleString() %>
                                    </td>

                                    <td class="p-4 font-sans text-zinc-400 capitalize">
                                        <%= payment.payment_method || 'N/A' %>
                                    </td>

                                    <td class="p-4 font-sans font-bold">

                                        <% if (paymentStatus === 'paid') { %>

                                            <span class="text-emerald-400 text-[10px] bg-emerald-950/40 border border-emerald-900/30 px-2 py-0.5 rounded">
                                                Paid
                                            </span>

                                        <% } else if (paymentStatus === 'partial') { %>

                                            <span class="text-amber-400 text-[10px] bg-amber-950/40 border border-amber-900/30 px-2 py-0.5 rounded">
                                                Partial
                                            </span>

                                        <% } else { %>

                                            <span class="text-red-400 text-[10px] bg-red-950/40 border border-red-900/30 px-2 py-0.5 rounded">
                                                Unpaid
                                            </span>

                                        <% } %>

                                    </td>

                                    <td class="p-4 font-sans text-[11px] text-zinc-400 max-w-xs">

                                        <% if (payment.notes) { %>

                                            <div class="bg-[#161616] border border-[#262626] rounded-lg p-2 leading-relaxed whitespace-pre-line">
                                                <%= payment.notes %>
                                            </div>

                                        <% } else { %>

                                            <span class="text-zinc-600">
                                                No later partial history
                                            </span>

                                        <% } %>

                                    </td>

                                    <td class="p-4 text-right font-sans whitespace-nowrap">

                                        <div class="inline-flex items-center gap-1">

                                            <% if (Number(payment.pending_amount || 0) > 0) { %>

                                                <a href="/rent/<%= payment.id %>/partial"
                                                   class="text-[10px] text-emerald-300 hover:text-emerald-200 bg-emerald-950/30 border border-emerald-700/40 px-2 py-1 rounded font-sans inline-block">
                                                    Receive Balance
                                                </a>

                                            <% } %>

                                            <a href="/rent/<%= payment.id %>/edit"
                                               class="text-[10px] text-zinc-300 hover:text-white bg-[#1A1A1C] border border-zinc-800 px-2 py-1 rounded font-sans inline-block">
                                                Edit
                                            </a>

                                            <form action="/rent/<%= payment.id %>/delete"
                                                  method="POST"
                                                  class="inline"
                                                  onsubmit="return confirm('WARNING: Are you sure you want to delete this payment record? This will permanently erase the transaction from historical ledgers.');">

                                                <button type="submit"
                                                        class="text-[10px] text-red-400 hover:text-red-300 bg-red-950/20 border border-red-900/30 px-2 py-1 rounded font-sans">
                                                    Delete
                                                </button>

                                            </form>

                                        </div>

                                    </td>

                                </tr>

                            <% }) %>

                        <% } else { %>

                            <tr>
                                <td colspan="9"
                                    class="p-8 text-center text-zinc-500 font-sans">
                                    No historical payment entries saved for this rental unit box.
                                </td>
                            </tr>

                        <% } %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>
</main>

<%- include('../partials/footer') %>
