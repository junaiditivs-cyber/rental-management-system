<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-16 border-b border-[#1F1F1F] px-8 flex items-center justify-between shrink-0">
        <div class="text-sm text-zinc-500">Units &gt; <span class="text-zinc-200 font-medium">Add Rentable Unit Box</span></div>
        <a href="javascript:history.back()" class="text-xs text-zinc-400 hover:text-white transition-colors">&larr; Back</a>
    </header>

    <div class="p-8 flex-1 overflow-y-auto max-w-2xl space-y-6">
        <div>
            <h1 class="text-white text-lg font-bold tracking-tight">Deploy Rentable Unit Node</h1>
            <p class="text-zinc-500 text-xs mt-1">Specify unit names, base floor, renting type, expected monthly rent, and advance security criteria.</p>
        </div>

        <form action="/units/add" method="POST" class="bg-[#111111] border border-[#262626] p-6 rounded-xl space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="property_select" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Select Property</label>
                    <select id="property_select" name="property_id" required onchange="filterFloorsByProperty(this.value)"
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        <option value="">-- Choose Property --</option>
                        <% properties.forEach(p => { %>
                            <option value="<%= p.id %>" <%= typeof p_prop_id !== 'undefined' && p_prop_id === p.id ? 'selected' : '' %>><%= p.name %> (<%= p.city_name %>)</option>
                        <% }) %>
                    </select>
                </div>

                <div>
                    <label for="floor_select" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Floor / Section</label>
                    <select id="floor_select" name="floor_id" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        <option value="">-- Choose Floor --</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="name" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Unit Name / Code</label>
                    <input type="text" id="name" name="name" required placeholder="e.g. Shop 01, Office 102"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-650 focus:outline-none focus:border-blue-500/80 transition-all">
                </div>

                <div>
                    <label for="unit_type" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Unit Type</label>
                    <select id="unit_type" name="unit_type" required
                            class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-zinc-300 text-sm focus:outline-none focus:border-blue-500/80 transition-all">
                        <option value="Shop">Shop</option>
                        <option value="Office">Office</option>
                        <option value="Apartment">Apartment</option>
                        <option value="Room">Room</option>
                        <option value="Hall">Hall</option>
                        <option value="Portion">Portion</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="rent_amount" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Monthly Rent (PKR)</label>
                    <input type="number" id="rent_amount" name="rent_amount" required min="0" placeholder="30000"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-650 focus:outline-none focus:border-blue-500/80 transition-all">
                </div>

                <div>
                    <label for="advance_amount" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Security Deposit Security (PKR)</label>
                    <input type="number" id="advance_amount" name="advance_amount" required min="0" placeholder="100000"
                           class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-650 focus:outline-none focus:border-blue-500/80 transition-all">
                </div>
            </div>

            <div>
                <label for="notes" class="block text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Access Notes / Amenities (Optional)</label>
                <textarea id="notes" name="notes" rows="3" placeholder="Describe layout, utility sub-meters, split levels..."
                          class="w-full px-3 py-2 bg-[#161616] border border-[#262626] rounded-md text-white text-sm placeholder-zinc-650 focus:outline-none focus:border-blue-500/80 transition-all"></textarea>
            </div>

            <div class="pt-4 border-t border-[#1F1F1F] flex justify-end gap-3">
                <button type="button" onclick="history.back()" class="px-4 py-2 bg-[#1A1A1A] hover:bg-[#2A2A2A] text-zinc-400 hover:text-white border border-[#262626] text-xs font-semibold rounded-md transition-all">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-white text-black hover:bg-zinc-200 text-xs font-bold rounded-md transition-all">
                    Deploy Box
                </button>
            </div>
        </form>
    </div>
</main>

<script>
    const floors = <%- JSON.stringify(floors) %>;
    const initialFloorId = "<%= typeof p_floor_id !== 'undefined' ? p_floor_id : '' %>";

    function filterFloorsByProperty(propertyId) {
        const floorSelect = document.getElementById('floor_select');
        floorSelect.innerHTML = '<option value="">-- Choose Floor --</option>';
        if (!propertyId) return;

        const filteredFloors = floors.filter(f => f.property_id === propertyId);
        filteredFloors.forEach(f => {
            const opt = document.createElement('option');
            opt.value = f.id;
            opt.textContent = f.name;
            if (initialFloorId && initialFloorId === f.id) {
                opt.selected = true;
            }
            floorSelect.appendChild(opt);
        });
    }

    // Auto load floor listings on first run if preset
    document.addEventListener('DOMContentLoaded', () => {
        const propId = document.getElementById('property_select').value;
        if (propId) {
            filterFloorsByProperty(propId);
        }
    });
</script>

<%- include('../partials/footer') %>
